# Copy to .env.prod and fill in.
# .env.prod is gitignored; .env.prod.example is committed.
#
# Required → must be set, deploy refuses to boot otherwise.
# Recommended → has a default but you almost always want to change.
# Optional → leave commented out unless you need it.

# ====================================================================
# REQUIRED
# ====================================================================

# Anything strong + random. 32+ bytes. `openssl rand -base64 48` is fine.
SECRET_KEY=

# Postgres password the `postgres` service will be created with.
# Must match what the memory-service connects with — docker-compose.yml
# builds DATABASE_URL from these.
POSTGRES_USER=memory
POSTGRES_PASSWORD=
POSTGRES_DB=memory_service

# At least one of these LLM / EMBEDDING combos must reach a real
# provider — health endpoint won't be green otherwise. See README.md
# §"LLM provider" for the supported shapes.
LLM_PROVIDER=openai
LLM_API_KEY=
# LLM_BASE_URL=         # only set for self-hosted / proxy
# LLM_MODEL=            # provider default if omitted

EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# EMBEDDING_MODEL=
# EMBEDDING_DIMENSIONS=


# ====================================================================
# RECOMMENDED
# ====================================================================

APP_ENV=production
LOG_LEVEL=INFO
# `json` ships single-line JSON to stderr, ready for ELK/loki/datadog.
# `text` is colored human-readable, use only for tail-following locally.
LOG_FORMAT=json

# Onboarding policy. `false` is the production-correct value — users
# come in only via admin-issued invites (POST /v1/users). Set `true`
# for open-signup demos / sandbox environments.
ALLOW_SELF_REGISTRATION=false

# Disable Graphiti's anonymous PostHog telemetry. Keep this off behind
# any TLS-inspecting proxy or air-gapped network.
GRAPHITI_TELEMETRY_ENABLED=false

# First user with this email is auto-promoted to super_admin on register.
# Drop this after the first deployment if you don't want it re-promoting
# anyone — existing super_admins keep their flag.
BOOTSTRAP_SUPER_ADMIN_EMAIL=

# CORS — comma-separated allowlist of origins your frontends serve from.
# Empty / unset disables CORS entirely (browser will block any
# cross-origin call). Use "*" only for dev.
CORS_ALLOW_ORIGINS=

# Where the service binds on the host. 127.0.0.1 means "only reachable
# from this host" — put nginx in front and proxy_pass to it. 0.0.0.0
# means "anyone who can reach this host's IP" — only do that if you
# trust the network (private VPC, internal-only).
MS_BIND=127.0.0.1
MS_PORT=8000

# Default reranking strategy. cross_encoder is best-quality but every
# /v1/search call hits the LLM — turn on only if budget allows.
SEARCH_RERANKER=rrf


# ====================================================================
# BUILD-TIME
# ====================================================================

# Set to "1" only when building from inside a TLS-inspecting corporate
# network (Fortinet, etc.) that breaks pypi cert verification. Tells
# the Dockerfile to pass --trusted-host on pip install. Production
# images built on real internet should leave this empty.
PIP_TRUSTED_HOSTS=
