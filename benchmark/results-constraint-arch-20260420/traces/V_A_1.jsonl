{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016ihdD2VUm3RaRnyXSnMFgD","type":"tool_result","content":"1\tpackage com.fortinet.nac.ingestion.converter;\n2\t\n3\timport com.fortinet.nac.common.dto.EntityDTO;\n4\timport com.fortinet.nac.ingestion.entity.Entity;\n5\timport org.springframework.stereotype.Component;\n6\t\n7\t/**\n8\t * Converter for Entity and EntityDTO conversion\n9\t */\n10\t@Component\n11\tpublic class EntityDTOConverter {\n12\t\n13\t    /**\n14\t     * Convert Entity to EntityDTO\n15\t     */\n16\t    public EntityDTO fromEntity(Entity entity) {\n17\t        if (entity == null) {\n18\t            return null;\n19\t        }\n20\t        EntityDTO dto = new EntityDTO();\n21\t        dto.setId(entity.getId());\n22\t        dto.setType(entity.getType());\n23\t        dto.setSource(entity.getSource());\n24\t        dto.setUserId(entity.getUserId());\n25\t        dto.setHostId(entity.getHostId());\n26\t        dto.setAdapterId(entity.getAdapterId());\n27\t        dto.setUserIdentity(entity.getUserIdentity());\n28\t        dto.setHostIdentity(entity.getHostIdentity());\n29\t        dto.setBindingType(entity.getBindingType());\n30\t        dto.setBindingStartTime(entity.getBindingStartTime());\n31\t        dto.setBindingEndTime(entity.getBindingEndTime());\n32\t        dto.setProcessingStage(entity.getProcessingStage());\n33\t        dto.setProcessingCode(entity.getProcessingCode());\n34\t        dto.setErrorMessage(entity.getErrorMessage());\n35\t        dto.setProcessingResult(entity.getProcessingResult());\n36\t        dto.setCreatedAt(entity.getCreatedAt());\n37\t        dto.setUpdatedAt(entity.getUpdatedAt());\n38\t        dto.setInterrupted(entity.isInterrupted());\n39\t        dto.setAttributeFingerprint(entity.getAttributeFingerprint());\n40\t        dto.setLastReqVersion(entity.getLastReqVersion());\n41\t        return dto;\n42\t    }\n43\t\n44\t    /**\n45\t     * Convert EntityDTO to Entity (only Entity's own fields)\n46\t     */\n47\t    public Entity toEntity(EntityDTO dto) {\n48\t        if (dto == null) {\n49\t            return null;\n50\t        }\n51\t        Entity entity = new Entity();\n52\t        entity.setId(dto.getId());\n53\t        entity.setType(dto.getType());\n54\t        entity.setSource(dto.getSource());\n55\t        entity.setUserId(dto.getUserId());\n56\t        entity.setHostId(dto.getHostId());\n57\t        entity.setAdapterId(dto.getAdapterId());\n58\t        entity.setUserIdentity(dto.getUserIdentity());\n59\t        entity.setHostIdentity(dto.getHostIdentity());\n60\t        entity.setBindingType(dto.getBindingType());\n61\t        entity.setBindingStartTime(dto.getBindingStartTime());\n62\t        entity.setBindingEndTime(dto.getBindingEndTime());\n63\t        entity.setProcessingStage(dto.getProcessingStage());\n64\t        entity.setProcessingCode(dto.getProcessingCode());\n65\t        entity.setErrorMessage(dto.getErrorMessage());\n66\t        entity.setProcessingResult(dto.getProcessingResult());\n67\t        entity.setCreatedAt(dto.getCreatedAt());\n68\t        entity.setUpdatedAt(dto.getUpdatedAt());\n69\t        entity.setInterrupted(dto.isInterrupted());\n70\t        entity.setAttributeFingerprint(dto.getAttributeFingerprint());\n71\t        entity.setLastReqVersion(dto.getLastReqVersion());\n72\t        return entity;\n73\t    }\n74\t}"}]},"parent_tool_use_id":"toolu_01RjnEyebv8PLzCNaSV25psr","session_id":"f940bc2a-3d26-4792-8791-db20803a6481","uuid":"52a83236-f76e-4679-853e-adf6dad76cfc","timestamp":"2026-04-20T08:08:18.692Z"}
