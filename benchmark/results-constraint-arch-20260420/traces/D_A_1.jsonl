{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UVxP3PHsqvvMfUTkxr1jHM","type":"tool_result","content":"1\tpackage com.fortinet.nac.ingestion.controller;\n2\t\n3\timport com.fortinet.nac.common.Constants;\n4\timport com.fortinet.nac.common.dto.IngestionRequest;\n5\timport com.fortinet.nac.common.dto.ResultDTO;\n6\timport com.fortinet.nac.common.redisstream.RedisStreamProducer;\n7\timport com.fortinet.nac.ingestion.registry.IngestionCallbackRegistry;\n8\t\n9\timport lombok.RequiredArgsConstructor;\n10\timport lombok.extern.slf4j.Slf4j;\n11\timport org.slf4j.MDC;\n12\timport org.springframework.beans.factory.annotation.Autowired;\n13\timport org.springframework.beans.factory.annotation.Qualifier;\n14\timport org.springframework.beans.factory.annotation.Value;\n15\timport org.springframework.validation.annotation.Validated;\n16\timport org.springframework.web.bind.annotation.*;\n17\timport reactor.core.publisher.Mono;\n18\timport reactor.core.scheduler.Schedulers;\n19\t\n20\timport java.time.Duration;\n21\timport java.util.UUID;\n22\timport java.util.concurrent.*;\n23\t\n24\t@RestController\n25\t@RequestMapping(\"/api/v1/ingestion\")\n26\t@RequiredArgsConstructor\n27\t@Slf4j\n28\tpublic class IngestionController {\n29\t\n30\t    private final RedisStreamProducer producer;\n31\t    private final IngestionCallbackRegistry callbackRegistry;\n32\t\n33\t    @Autowired\n34\t    @Qualifier(\"nettyOffloadExecutor\")\n35\t    private ExecutorService nettyOffloadExecutor;\n36\t\n37\t    @Value(\"${ingestion.response-timeout:60}\")\n38\t    private int responseTimeout;\n39\t\n40\t    private final int HTTP_INTERNAL_SERVER_ERROR = 500;\n41\t\n42\t    @PostMapping(\"/events\")\n43\t    public Mono<ResultDTO<?>> ingestEvent(@RequestBody @Validated IngestionRequest req) {\n44\t\n45\t        return Mono.deferContextual(ctx -> {\n46\t\n47\t            // Step 1: prepare request\n48\t            req.setRequestId(generateRequestId());\n49\t            req.setAsync(false);\n50\t\n51\t            String traceId = ctx.getOrDefault(Constants.TRACE_ID, generateRequestId());\n52\t            req.setTraceId(traceId);\n53\t\n54\t            // put traceId into MDC for current thread so logback [%X{traceId}] works\n55\t            try (MDC.MDCCloseable ignored = MDC.putCloseable(Constants.TRACE_ID, traceId)) {\n56\t\n57\t                log.info(\"REST ingestion request arrived: requestId={}\", req.getRequestId());\n58\t\n59\t                // Step 2: register callback future\n60\t                CompletableFuture<ResultDTO<?>> future =\n61\t                    callbackRegistry.register(req.getRequestId());\n62\t\n63\t                // Add a timeout to the future itself to ensure the registry does not have memory leak.\n64\t                //\n65\t                // If the internal processing never calls callbackRegistry.complete(...)\n66\t                // (e.g., consumer crash, message loss, or the message stays pending forever),\n67\t                // the registry would otherwise leak memory.\n68\t                future.orTimeout(responseTimeout, TimeUnit.SECONDS)\n69\t                        .whenComplete((r, e) -> callbackRegistry.unregister(req.getRequestId()));\n70\t"}]},"parent_tool_use_id":"toolu_01V9dSVq7R44hZcW7AvRignC","session_id":"4d66882d-4e4c-4193-a30d-0a97622c72bf","uuid":"d929a22e-a504-4550-af74-b2a30417dd64","timestamp":"2026-04-20T08:12:25.400Z"}
