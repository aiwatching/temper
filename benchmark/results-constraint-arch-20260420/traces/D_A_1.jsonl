{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K8g5aKZsLpet1ePctzzm5o","type":"tool_result","content":"1\tpackage com.fortinet.nac.ingestion.e2e;\n2\t\n3\timport com.fortinet.nac.common.enums.EntityStage;\n4\timport com.fortinet.nac.common.enums.EntityType;\n5\timport com.fortinet.nac.common.enums.ReprocessState;\n6\timport com.fortinet.nac.ingestion.entity.Entity;\n7\timport com.fortinet.nac.ingestion.service.EntityService;\n8\timport org.junit.jupiter.api.*;\n9\timport org.junit.jupiter.api.condition.EnabledIfSystemProperty;\n10\timport org.springframework.beans.factory.annotation.Autowired;\n11\timport org.springframework.boot.test.context.SpringBootTest;\n12\timport org.springframework.boot.web.server.LocalServerPort;\n13\timport org.springframework.http.MediaType;\n14\timport org.springframework.test.context.DynamicPropertyRegistry;\n15\timport org.springframework.test.context.DynamicPropertySource;\n16\timport org.springframework.test.web.reactive.server.WebTestClient;\n17\timport org.springframework.scheduling.annotation.EnableScheduling;\n18\timport org.testcontainers.containers.GenericContainer;\n19\timport org.testcontainers.containers.MariaDBContainer;\n20\timport org.testcontainers.junit.jupiter.Container;\n21\timport org.testcontainers.junit.jupiter.Testcontainers;\n22\t\n23\timport java.io.InputStream;\n24\timport java.sql.Connection;\n25\timport java.sql.DriverManager;\n26\timport java.time.Duration;\n27\timport java.time.Instant;\n28\timport java.util.ArrayList;\n29\timport java.util.List;\n30\timport java.util.concurrent.TimeUnit;\n31\t\n32\timport static org.testcontainers.shaded.org.awaitility.Awaitility.await;\n33\t\n34\t@Testcontainers\n35\t// Start a real HTTP server (Netty), listening on a random port (stored in 'port').\n36\t@SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)\n37\t@EnableScheduling  // Enable scheduling for PolicyReprocessJob\n38\t@TestMethodOrder(MethodOrderer.OrderAnnotation.class)\n39\t@EnabledIfSystemProperty(named = \"runTestContainerInDev\", matches = \"true\")\n40\tpublic class PolicyReprocessJobE2ETest {\n41\t\n42\t    @BeforeAll\n43\t    static void initSchema() throws Exception {\n44\t        List<String> scripts = List.of(\"sql/classification_test_ddl.sql\", \"sql/entity.sql\");\n45\t\n46\t        try (Connection conn = DriverManager.getConnection(\n47\t                mariadb.getJdbcUrl(), \"root\", \"dummy\")) {\n48\t            for (String script : scripts) {\n49\t                InputStream is = PolicyReprocessJobE2ETest.class.getClassLoader()\n50\t                    .getResourceAsStream(script);\n51\t\n52\t                Assertions.assertNotNull(is);\n53\t\n54\t                String ddl = new String(is.readAllBytes());\n55\t\n56\t                for (String sql : ddl.split(\";\")) {\n57\t                    sql = sql.trim();\n58\t                    if (!sql.isEmpty()) {\n59\t                        conn.createStatement().execute(sql);\n60\t                    }\n61\t                }\n62\t            }\n63\t        }\n64\t    }\n65\t\n66\t    // Redis\n67\t    @Container\n68\t    static GenericContainer<?> redis = new GenericContainer<>(\"redis:7.2.4\")\n69\t            .withExposedPorts(6379);\n70\t\n71\t    // MariaDB\n72\t    @Container\n73\t    static MariaDBContainer<?> mariadb = new MariaDBContainer<>(\"mariadb:10.7.8\")\n74\t            .withDatabaseName(\"bsc\")\n75\t            .withUsername(\"root\")\n76\t            .withPassword(\"dummy\");\n77\t\n78\t    @DynamicPropertySource\n79\t    static void injectProps(DynamicPropertyRegistry registry) {\n80\t        // Redis config overrides\n81\t        registry.add(\"spring.redis.host\", redis::getHost);\n82\t        registry.add(\"spring.redis.port\", redis::getFirstMappedPort);\n83\t        registry.add(\"spring.redis.timeout\", () -> \"15000\");\n84\t\n85\t        // Database config overrides\n86\t        registry.add(\"spring.datasource.url\", mariadb::getJdbcUrl);\n87\t        registry.add(\"spring.datasource.username\", mariadb::getUsername);\n88\t        registry.add(\"spring.datasource.password\", mariadb::getPassword);\n89\t\n90\t        // Policy reprocess job config - run more frequently for testing\n91\t        registry.add(\"policy.reprocess.scan-interval-ms\", () -> \"1000\");\n92\t    }\n93\t\n94\t    @LocalServerPort\n95\t    int port;\n96\t\n97\t    @Autowired\n98\t    private WebTestClient webClient;\n99\t\n100\t    @Autowired\n101\t    private EntityService entityService;\n102\t\n103\t    @BeforeEach\n104\t    void setup() {\n105\t        webClient = webClient.mutate().responseTimeout(Duration.ofSeconds(30)).build();\n106\t    }\n107\t\n108\t    @Test\n109\t    void testPolicyReprocessJobEndToEnd() {\n110\t        // Create test entities with NONE reprocess state\n111\t        List<Entity> entities = new ArrayList<>();\n112\t        for (int i = 1; i <= 5; i++) {\n113\t            Entity e = Entity.builder()\n114\t                    .type(EntityType.USER_HOST_BINDING)\n115\t                    .source(\"PORTAL\")\n116\t                    .userId(String.valueOf(i))\n117\t                    .hostId(String.valueOf(i))\n118\t                    .adapterId(String.valueOf(i))\n119\t                    .userIdentity(String.valueOf(i))\n120\t                    .hostIdentity(i + \"_\" + i)\n121\t                    .processingStage(\"ENFORCED\")\n122\t                    .processingCode(0)\n123\t                    .attributeFingerprint(\"fp-\" + i)\n124\t                    .lastReqVersion(\"1\")\n125\t                    .reprocessState(ReprocessState.NONE)\n126\t                    .createdAt(Instant.now())\n127\t                    .updatedAt(Instant.now())\n128\t                    .build();\n129\t            entities.add(e);\n130\t        }\n131\t        entityService.saveBatch(entities);\n132\t\n133\t        // Verify entities were created with NONE reprocess state\n134\t        List<Long> savedEntities = entityService.findTopNIdsByReprocessState(ReprocessState.NONE, 10);\n135\t        Assertions.assertEquals(5, savedEntities.size(), \"Should have exactly 5 entities with NONE reprocess state\");\n136\t\n137\t        // Call the endpoint to mark all for reprocessing and verify response payload\n138\t        webClient.post()\n139\t                .uri(\"http://localhost:\" + port + \"/api/v1/policy/apply-existing-entities\")\n140\t                .contentType(MediaType.APPLICATION_JSON)\n141\t                .exchange()\n142\t                .expectStatus().isOk()\n143\t                .expectBody()\n144\t                .jsonPath(\"$.code\").isEqualTo(200)\n145\t                .jsonPath(\"$.data.markedCount\").isEqualTo(5)\n146\t                .jsonPath(\"$.data.message\").value(message ->\n147\t                        Assertions.assertTrue(((String) message).contains(\"Marked 5 entities for reprocessing\"),\n148\t                                \"Response should indicate 5 entities were marked for reprocessing\"));\n149\t\n150\t        // Wait a bit for the operation to complete"}]},"parent_tool_use_id":"toolu_01V9dSVq7R44hZcW7AvRignC","session_id":"4d66882d-4e4c-4193-a30d-0a97622c72bf","uuid":"9e04ca82-dedd-4c11-9897-b6ec297e197c","timestamp":"2026-04-20T08:12:45.052Z"}
