{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NusfovwpP3yZF4PrNvrPjQ","type":"tool_result","content":"1\tpackage com.fortinet.nac.ingestion.config;\n2\t\n3\timport org.springframework.beans.factory.annotation.Value;\n4\timport org.springframework.context.annotation.Bean;\n5\timport org.springframework.context.annotation.Configuration;\n6\timport org.springframework.scheduling.concurrent.ThreadPoolTaskExecutor;\n7\t\n8\timport java.util.concurrent.Executor;\n9\timport java.util.concurrent.ThreadPoolExecutor;\n10\t\n11\t@Configuration\n12\tpublic class PolicyReprocessAsyncConfig {\n13\t\n14\t    @Value(\"${policy.reprocess.listener.core-size:1}\")\n15\t    private int listenerCoreSize;\n16\t\n17\t    @Value(\"${policy.reprocess.listener.max-size:2}\")\n18\t    private int listenerMaxSize;\n19\t\n20\t    @Value(\"${policy.reprocess.listener.queue-capacity:100}\")\n21\t    private int listenerQueueCapacity;\n22\t\n23\t    @Value(\"${policy.reprocess.listener.keep-alive-seconds:60}\")\n24\t    private int listenerKeepAliveSeconds;\n25\t\n26\t    @Value(\"${policy.reprocess.job.core-size:8}\")\n27\t    private int jobCoreSize;\n28\t\n29\t    @Value(\"${policy.reprocess.job.max-size:16}\")\n30\t    private int jobMaxSize;\n31\t\n32\t    @Value(\"${policy.reprocess.job.queue-capacity:32}\")\n33\t    private int jobQueueCapacity;\n34\t\n35\t    @Value(\"${policy.reprocess.job.keep-alive-seconds:60}\")\n36\t    private int jobKeepAliveSeconds;\n37\t\n38\t    @Bean(\"policyReprocessListenerExecutor\")\n39\t    public Executor policyReprocessListenerExecutor() {\n40\t        ThreadPoolTaskExecutor executor = new ThreadPoolTaskExecutor();\n41\t        executor.setCorePoolSize(listenerCoreSize);\n42\t        executor.setMaxPoolSize(listenerMaxSize);\n43\t        executor.setQueueCapacity(listenerQueueCapacity);\n44\t        executor.setKeepAliveSeconds(listenerKeepAliveSeconds);\n45\t        executor.setThreadNamePrefix(\"policy-reprocess-listener-\");\n46\t        executor.setRejectedExecutionHandler(new ThreadPoolExecutor.CallerRunsPolicy());\n47\t        executor.initialize();\n48\t        return executor;\n49\t    }\n50\t\n51\t    @Bean(\"policyReprocessJobExecutor\")\n52\t    public Executor policyReprocessJobExecutor() {\n53\t        int effectiveCoreSize = Math.max(1, jobCoreSize);\n54\t        int effectiveMaxSize = Math.max(effectiveCoreSize, jobMaxSize);\n55\t        ThreadPoolTaskExecutor executor = new ThreadPoolTaskExecutor();\n56\t        executor.setCorePoolSize(effectiveCoreSize);\n57\t        executor.setMaxPoolSize(effectiveMaxSize);\n58\t        executor.setQueueCapacity(jobQueueCapacity);\n59\t        executor.setKeepAliveSeconds(jobKeepAliveSeconds);\n60\t        executor.setThreadNamePrefix(\"policy-reprocess-job-\");\n61\t        executor.setRejectedExecutionHandler(new ThreadPoolExecutor.CallerRunsPolicy());\n62\t        executor.initialize();\n63\t        return executor;\n64\t    }\n65\t}\n66\t"}]},"parent_tool_use_id":"toolu_01SPCTUaXSmmm11PXF2zmWy8","session_id":"52431531-98c4-408a-846e-cbcca2319a2d","uuid":"b8db5c37-51ab-4855-928c-040f96cbcfc0","timestamp":"2026-04-20T08:23:04.561Z"}
