{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CcU1cRJ6cPGGVmxENh2SpE","type":"tool_result","content":"1\tpackage com.fortinet.nac.ingestion.controller;\n2\t\n3\timport com.fortinet.nac.common.dto.Pagination;\n4\timport com.fortinet.nac.common.dto.ResultDTO;\n5\timport com.fortinet.nac.common.enums.ReprocessState;\n6\timport com.fortinet.nac.ingestion.dto.EntityQueryDTO;\n7\timport com.fortinet.nac.ingestion.dto.EntityStateDisplayDTO;\n8\timport com.fortinet.nac.ingestion.entity.Entity;\n9\timport com.fortinet.nac.ingestion.service.EntityService;\n10\t\n11\timport org.springframework.web.bind.annotation.*;\n12\t\n13\timport javax.annotation.Resource;\n14\t\n15\t@RestController\n16\t@RequestMapping(\"/api/v1/entities\")\n17\tpublic class EntityController {\n18\t\n19\t    @Resource\n20\t    private EntityService entityService;\n21\t\n22\t    @PostMapping(\"/query\")\n23\t    public ResultDTO<Pagination<Entity>> queryFailedEntities(@RequestBody EntityQueryDTO req) {\n24\t        Pagination<Entity> page = entityService.queryFailedEntities(req);\n25\t        return ResultDTO.success(page);\n26\t    }\n27\t\n28\t    @GetMapping(\"/{id}\")\n29\t    public Entity getEntity(@PathVariable Long id) {\n30\t        return entityService.getById(id);\n31\t    }\n32\t\n33\t    @GetMapping(\"/{id}/display-status\")\n34\t    public ResultDTO<EntityStateDisplayDTO> getEntityDisplayStatus(@PathVariable Long id) {\n35\t        Entity entity = entityService.getById(id);\n36\t        if (entity == null) {\n37\t            return (ResultDTO<EntityStateDisplayDTO>) ResultDTO.error(\"Entity not found\");\n38\t        }\n39\t\n40\t        EntityStateDisplayDTO dto = new EntityStateDisplayDTO();\n41\t        dto.setId(entity.getId());\n42\t        dto.setType(entity.getType().toString());\n43\t        dto.setHostIdentity(entity.getHostIdentity());\n44\t        dto.setUserIdentity(entity.getUserIdentity());\n45\t        dto.setProcessingStage(entity.getProcessingStage());\n46\t        dto.setProcessingCode(entity.getProcessingCode());\n47\t        dto.setUpdatedAt(entity.getUpdatedAt());\n48\t\n49\t        // Map display status from reprocessState and processingStage.\n50\t        String displayStatus = mapToDisplayStatus(entity);\n51\t        dto.setDisplayStatus(displayStatus);\n52\t\n53\t        return ResultDTO.success(dto);\n54\t    }\n55\t\n56\t    private String mapToDisplayStatus(Entity entity) {\n57\t        ReprocessState reprocessState = entity.getReprocessState();\n58\t        if (reprocessState == null) {\n59\t            reprocessState = ReprocessState.NONE;\n60\t        }\n61\t\n62\t        switch (reprocessState) {\n63\t            case INIT:\n64\t                return \"init\";\n65\t            case RUNNING:\n66\t                return \"running\";\n67\t            case SUCCESS:\n68\t                // Count as enforced only when reprocessState=SUCCESS, processingStage=ENFORCED, and processingCode=0.\n69\t                if (\"ENFORCED\".equals(entity.getProcessingStage()) &&\n70\t                    (entity.getProcessingCode() == null || entity.getProcessingCode() == 0)) {\n71\t                    return \"enforced\";\n72\t                } else {\n73\t                    return \"failed\";\n74\t                }\n75\t            case FAILED:\n76\t                return \"failed\";\n77\t            case NONE:\n78\t            default:\n79\t                // If reprocessState is missing, derive display status directly from processingStage.\n80\t                if (\"ENFORCED\".equals(entity.getProcessingStage()) &&\n81\t                    (entity.getProcessingCode() == null || entity.getProcessingCode() == 0)) {\n82\t                    return \"enforced\";\n83\t                } else {\n84\t                    return entity.getProcessingStage() != null ? entity.getProcessingStage().toLowerCase() : \"unknown\";\n85\t                }\n86\t        }\n87\t    }\n88\t}\n89\t"}]},"parent_tool_use_id":"toolu_01SP