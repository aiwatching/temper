{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JToBEGazFHKnQmXS25Z5QG","type":"tool_result","content":"1\tpackage com.fortinet.nac.ingestion.config;\n2\t\n3\timport io.micrometer.core.instrument.Gauge;\n4\timport io.micrometer.core.instrument.MeterRegistry;\n5\timport io.micrometer.core.instrument.binder.jvm.ExecutorServiceMetrics;\n6\t\n7\timport org.springframework.beans.factory.annotation.Value;\n8\timport org.springframework.context.annotation.Bean;\n9\timport org.springframework.context.annotation.Configuration;\n10\t\n11\timport java.util.concurrent.*;\n12\t\n13\t@Configuration\n14\tpublic class NettyOffLoadThreadPoolConfig {\n15\t\n16\t    @Value(\"${ingestion.reactive.thread-pool.core-size:30}\")\n17\t    private int coreSize;\n18\t\n19\t    @Value(\"${ingestion.reactive.thread-pool.max-size:300}\")\n20\t    private int maxSize;\n21\t\n22\t    @Value(\"${ingestion.reactive.thread-pool.queue-capacity:10000}\")\n23\t    private int queueCapacity;\n24\t\n25\t    @Value(\"${ingestion.reactive.thread-pool.keep-alive-seconds:60}\")\n26\t    private int keepAliveSeconds;\n27\t\n28\t    @Bean(\"nettyOffloadExecutor\")\n29\t    public ExecutorService nettyOffloadExecutor(MeterRegistry registry) {\n30\t        ThreadPoolExecutor raw = new ThreadPoolExecutor(\n31\t                coreSize,\n32\t                maxSize,\n33\t                keepAliveSeconds, TimeUnit.SECONDS,\n34\t                new LinkedBlockingQueue<>(queueCapacity),\n35\t                new NamedThreadFactory(\"netty-offload\"),\n36\t                new ThreadPoolExecutor.CallerRunsPolicy()\n37\t        );\n38\t\n39\t        // Bind to Micrometer: so that executor_* metrics are visible in /actuator/prometheus*\n40\t        ExecutorServiceMetrics.monitor(registry, raw, \"netty_offload\");\n41\t\n42\t        // active: the number of threads currently executing tasks (inside run())\n43\t        //         If active ≈ pool size: the thread pool is nearly fully utilized.\n44\t        //         If active = pool size for a long time: there is a bottleneck in CPU / I/O / Redis / DB.\n45\t        //         If active is much smaller than the pool size:\n46\t        Gauge.builder(\"netty_offload_active_threads\", raw, ThreadPoolExecutor::getActiveCount)\n47\t                .description(\"Active threads in nettyOffloadExecutor pool\")\n48\t                .register(registry);\n49\t\n50\t        // pool size: the number of threads that have been created and are not yet destroyed\n51\t        Gauge.builder(\"netty_offload_pool_size_threads\", raw, ThreadPoolExecutor::getPoolSize)\n52\t                .description(\"Current number of threads in the pool\")\n53\t                .register(registry);\n54\t\n55\t        // corePoolSize: the minimum number of threads that are kept alive in the thread pool\n56\t        Gauge.builder(\"netty_offload_pool_core_threads\", raw, ThreadPoolExecutor::getCorePoolSize)\n57\t                .description(\"Core number of threads for the pool\")\n58\t                .register(registry);\n59\t\n60\t        // max size: the maximum number of threads allowed in the thread pool (a hard limit)\n61\t        Gauge.builder(\"netty_offload_pool_max_threads\", raw, ThreadPoolExecutor::getMaximumPoolSize)\n62\t                .description(\"Maximum allowed number of threads in the pool\")\n63\t                .register(registry);\n64\t\n65\t        // queue: the number of tasks that have been submitted to the thread pool\n66\t        //        but have not yet been picked up by any thread.\n67\t        //\n68\t        //        If queue = 0: the thread pool is keeping up completely\n69\t        //        If queue keeps growing: consumption speed < production speed\n70\t        //        If queue stays large for a long time: tasks are “buffering” inside the JVM\n71\t        Gauge.builder(\"netty_offload_queue_size_tasks\", raw, e -> e.getQueue().size())\n72\t                .description(\"Approximate number of tasks in the queue\")\n73\t                .register(registry);\n74\t\n75\t        // only used when debugging\n76\t        //        Gauge.builder(\"netty_offload_queue_remaining_tasks\", raw, e -> e.getQueue().remainingCapacity())\n77\t        //                .description(\"Number of additional tasks the queue can ideally accept\")\n78\t        //                .register(registry);\n79\t        //\n80\t        //        Gauge.builder(\"netty_offload_completed_tasks_total\", raw, e -> (double) e.getCompletedTaskCount())\n81\t        //                .description(\"Approximate total number of tasks that have completed execution\")\n82\t        //                .register(registry);\n83\t        //\n84\t        //        Gauge.builder(\"netty_offload_task_count_total\", raw, e -> (double) e.getTaskCount())\n85\t        //                .description(\"Approximate total number of tasks that have ever been scheduled for execution\")\n86\t        //                .register(registry);\n87\t\n88\t        return raw;\n89\t    }\n90\t}\n91\t\n92\t"}]},"parent_tool_use_id":"toolu_01SPCTUaXSmmm11PXF2zmWy8","session_id":"52431531-98c4-408a-846e-cbcca2319a2d","uuid":"9189a787-453b-47ec-9adb-c38bf263d7ca","timestamp":"2026-04-20T08:23:04.333Z"}
