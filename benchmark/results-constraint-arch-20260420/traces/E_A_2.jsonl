{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RCZH9VhmFpvRHdAoaVGDM3","type":"tool_result","content":"1\tpackage com.fortinet.nac.ingestion.service.stages;\n2\t\n3\timport com.fasterxml.jackson.core.type.TypeReference;\n4\timport com.fasterxml.jackson.databind.ObjectMapper;\n5\timport com.fasterxml.jackson.databind.node.ObjectNode;\n6\timport com.fortinet.nac.classification.api.dto.label.LabelReference;\n7\timport com.fortinet.nac.classification.api.dto.label.ObjectNodeIdempotentRequest;\n8\timport com.fortinet.nac.classification.service.ObjectNodeService;\n9\timport com.fortinet.nac.classification.service.RuleEngineService;\n10\timport com.fortinet.nac.common.enums.EntityProcessingCode;\n11\timport com.fortinet.nac.common.dto.EntityDTO;\n12\timport lombok.RequiredArgsConstructor;\n13\timport org.springframework.stereotype.Service;\n14\timport org.springframework.transaction.annotation.Transactional;\n15\t\n16\timport java.util.ArrayList;\n17\timport java.util.HashMap;\n18\timport java.util.List;\n19\timport java.util.Map;\n20\t\n21\t@Service\n22\t@RequiredArgsConstructor\n23\tpublic class LabelService {\n24\t    // Label stage processing codes are defined in EntityProcessingCode.Label class\n25\t    // Current success code: EntityProcessingCode.SUCCESS (0)\n26\t    // To add new codes, follow the convention in EntityProcessingCode.java:\n27\t    // - 21xx for temporary/retryable errors\n28\t    // - 22xx for permanent errors\n29\t    // Example: public static final int MY_NEW_ERROR = 2250;\n30\t\n31\t    private final ObjectMapper objectMapper;\n32\t\n33\t    private final RuleEngineService ruleEngineService;\n34\t\n35\t    private final ObjectNodeService objectNodeService;\n36\t\n37\t    /**\n38\t     * @return ObjectNode:\n39\t     *      Success: { \"code\": 0, \"data\": { ... } }\n40\t     *      Failure: { \"code\": <non-zero>, \"errMessage\": \"...\" }\n41\t     */\n42\t    public ObjectNode label(EntityDTO dto) {\n43\t        return StageExecutor.execute(dto, this::doLabel);\n44\t    }\n45\t\n46\t    @Transactional\n47\t    public ObjectNode doLabel(EntityDTO dto) {\n48\t        Map<String, Object> input = objectMapper.convertValue(dto, new TypeReference<>() {});\n49\t        ObjectNodeIdempotentRequest request = new ObjectNodeIdempotentRequest();\n50\t        request.setObjectId(dto.getId());\n51\t        Map<String, Object> properties = new HashMap<>();\n52\t        properties.put(\"EntityDTO\", dto);\n53\t        request.setProperties(properties);\n54\t\n55\t        if(dto.getUserId() != null) {\n56\t            input = ruleEngineService.execute(\"USER\", \"USER\", input);\n57\t            request.setNodeType(\"USER\");\n58\t        }\n59\t\n60\t        if (dto.getHostId() != null) {\n61\t            input = ruleEngineService.execute(\"HOST\", \"HOST\", input);\n62\t            request.setNodeType(\"HOST\");\n63\t        }\n64\t\n65\t        if (dto.getAdapterId() != null) {\n66\t            input = ruleEngineService.execute(\"ADAPTER\", \"ADAPTER\", input);\n67\t            request.setNodeType(\"ADAPTER\");\n68\t        }\n69\t\n70\t        @SuppressWarnings(\"unchecked\")\n71\t        Map<String, String> labels = (Map<String, String>) input.get(\"__labels__\");\n72\t        List<LabelReference> labelRefs = new ArrayList<>();\n73\t        for (Map.Entry<String, String> entry : labels.entrySet()) {\n74\t            LabelReference labelRef = new LabelReference();\n75\t            labelRef.setLabelType(entry.getKey());\n76\t            labelRef.setName(entry.getValue());\n77\t            labelRefs.add(labelRef);\n78\t        }\n79\t        request.setLabels(labelRefs);\n80\t        objectNodeService.handleLabelAssociations(request);"}]},"parent_tool_use_id":"toolu_01SPCTUaXSmmm11PXF2zmWy8","session_id":"52431531-98c4-408a-846e-cbcca2319a2d","uuid":"5f8bdfd3-0bd5-41f6-b051-23970e018b96","timestamp":"2026-04-20T08:23:21.837Z"}
