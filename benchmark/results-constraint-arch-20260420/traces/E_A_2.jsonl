nsaction.PlatformTransactionManager;\nimport org.springframework.transaction.TransactionDefinition;\nimport org.springframework.transaction.annotation.Propagation;\nimport org.springframework.transaction.annotation.Transactional;\nimport org.springframework.transaction.support.TransactionTemplate;\n\nimport javax.annotation.PostConstruct;\nimport javax.persistence.criteria.Predicate;\nimport java.time.Duration;\nimport java.time.Instant;\nimport java.util.*;\nimport java.util.concurrent.atomic.AtomicInteger;\n\n@Slf4j\n@Service\n@RequiredArgsConstructor\npublic class EntityServiceImpl implements EntityService {\n\n    private final EntityRepository entityRepository;\n\n    @Qualifier(\"IngestionIdService\")\n    private final IdService idService;\n\n    private final PlatformTransactionManager transactionManager;\n    private final MeterRegistry meterRegistry;\n    private final AtomicInteger markInitLastFailedBatches = new AtomicInteger(0);\n\n    @Value(\"${policy.reprocess.mark-init-batch-size:1000}\")\n    private int markInitBatchSize;\n\n    @PostConstruct\n    public void initMetrics() {\n        meterRegistry.gauge(\"policy_reprocess_mark_init_last_failed_batches\", markInitLastFailedBatches);\n    }\n\n    @Override\n    public Entity getById(Long id) {\n        return entityRepository.findById(id).orElse(null);\n    }\n\n    @Override\n    public void save(Entity entity) {\n        if (entity.getId() == null) {\n            entity.setId(idService.nextId());\n        }\n\n        Instant now = Instant.now();\n\n        if (entity.getCreatedAt() == null) {\n            entity.setCreatedAt(now);\n        }\n        if (entity.getUpdatedAt() == null) {\n            entity.setUpdatedAt(now);\n        }\n\n        entityRepository.save(entity);\n    }\n\n    @Override\n    public void saveBatch(Collection<Entity> entityList) {\n        Instant now = Instant.now();\n\n        for (Entity e : entityList) {\n            if (e.getId() == null) {\n                e.setId(idService.nextId());\n            }\n\n            if (e.getCreatedAt() == null) {\n                e.setCreatedAt(now);\n            }\n            if (e.getUpdatedAt() == null) {\n                e.setUpdatedAt(now);\n            }\n        }\n        entityRepository.saveAll(entityList);\n    }\n\n    public boolean isInterrupted(long entityId) {\n        return entityRepository.findById(entityId)\n                .map(Entity::isInterrupted)\n                .orElse(false);\n    }\n\n    // Use a separate transaction to guarantee the state update is committed,\n    // even if the outer transaction fails or is rolled back.\n    @Transactional(propagation = Propagation.REQUIRES_NEW)\n    public boolean setInterrupted(Long entityId, boolean interrupted) {\n        int rows = entityRepository.updateInterrupted(entityId, interrupted, Instant.now());\n        if (rows == 0) {\n            log.error(\"setInterrupted rows=0, id={}, interrupted={}\", entityId, interrupted);\n            return false;\n        }\n        return true;\n    }\n\n    public Entity getEntity(Long id) {\n        return entityRepository.findById(id).orElse(null);\n    }\n\n    /**\n     * Query database based on entity type + identity\n     */\n    public Entity getEntity(IngestionRequest req) {\n        String type = req.getEntityType();\n\n        // HOST\n        if (\"HOST\".equalsIgnoreCase(type)) {\n            String hostIdentity = req.getHostId() + \"_\" + req.getAdapterId();\n            return entityRepository\n                    .findFirstByTypeAndHostIdentity(EntityType.HOST, hostIdentity)\n                    .orElse(null);\n        }\n\n        // USER_HOST_BINDING\n        String hostIdentity = req.getHostId() + \"_\" + req.getAdapterId();\n        return entityRepository\n                .findFirstByTypeAndHostIdentityAndUserIdentity(\n                        EntityType.USER_HOST_BINDING, hostIdentity, req.getUserId()\n                )\n                .orElse(null);\n    }\n\n    @Override\n    public Pagination<Entity> queryFailedEntities(EntityQueryDTO req) {\n\n        Specification<Entity> spec = (root, query, cb) -> {\n            List<Predicate> predicates = new ArrayList<>();\n\n            if (req.getStage() != null && !req.getStage().isEmpty()) {\n                predicates.add(cb.equal(root.get(\"processingStage\"), req.getStage()));\n            }\n\n            if (req.getCode() != null) {\n                predicates.add(cb.equal(root.get(\"processingCode\"), req.getCode()));\n            } else {\n                predicates.add(cb.notEqual(root.get(\"processingCode\"), 0));\n            }\n\n            return cb.and(predicates.toArray(new Predicate[0]));\n        };\n\n        String sortKey = req.getSortKey();\n        boolean asc = \"asc\".equalsIgnoreCase(req.getSortOrder());\n\n        if (sortKey == null || sortKey.isEmpty()) {\n            sortKey = \"createdAt\";\n        }\n\n        String sortProperty;\n        switch (sortKey) {\n            case \"processingStage\":\n                sortProperty = \"processingStage\";\n                break;\n            case \"type\":\n                sortProperty = \"type\";\n                break;\n            case \"createdAt\":\n            default:\n                sortProperty = \"createdAt\";\n                break;\n        }\n\n        Sort sort = Sort.by(asc ? Sort.Direction.ASC : Sort.Direction.DESC, sortProperty);\n        Pageable pageable = PageRequest.of(\n                Math.max(0, req.getPageNum() - 1),\n                req.getPageSize(),\n                sort\n        );\n\n        Page<Entity> page = entityRepository.findAll(spec, pageable);\n\n        return Pagination.<Entity>builder()\n                .list(page.getContent())\n                .totalRecords(page.getTotalElements())\n                .totalPages(page.getTotalPages())\n                .pageNum(page.getNumber() + 1)\n                .pageSize(page.getSize())\n                .build();\n    }\n\n    @Override\n    public boolean isProcessingFinished(Long entityId) {\n        Entity e = entityRepository.findById(entityId).orElse(null);\n        if (e == null) {\n            return true;\n        }\n\n        if (\"ENFORCED\".equalsIgnoreCase(e.getProcessingStage())) {\n            return true;\n        }\n\n        // processingCode != 0: indicates failure and exit\n        Integer code = e.getProcessingCode();\n        return code != null && code != 0;\n    }\n\n    @Override\n    @Transactional(propagation = Propagation.REQUIRES_NEW)\n    public boolean updateProcessingState(Entity fresh) {\n        if (fresh == null || fresh.getId() == null) return false;\n\n        fresh.setUpdatedAt(Instant.now());\n\n        int rows = entityRepository.updateProcessingState(\n                fresh.getId(),\n                fresh.isInterrupted(),\n                fresh.getAttributeFingerprint(),\n                fresh.getProcessingStage(),\n                fresh.getProcessingCode(),\n                fresh.getLastReqVersion(),\n                fresh.getProcessingResult(),\n                fresh.getUpdatedAt()\n        );\n        if (rows == 0) log.error(\"updateProcessingState rows=0, id={}, stage={}\", fresh.getId(), fresh.getProcessingStage());\n        return rows > 0;\n    }\n\n    @Override\n    public List<Entity> findStuckEntities(Duration staleThreshold, int maxCount) {\n        Instant before = Instant.now().minus(staleThreshold);\n        var pageable = PageRequest.of(0, maxCount);\n\n        Page<Entity> page = entityRepository.findStuckEntities(before, pageable);\n        List<Entity> result = page.getContent();\n        if (!result.isEmpty()) {\n            log.info(\"findStuckEntities: found {} candidates before={}, threshold={}\",\n                    result.size(), before, staleThreshold);\n        }\n        return result;\n    }\n\n    // Mark entities that need reprocessing to INIT in batches, and return total updated rows.\n    @Override\n    public MarkForReprocessResult markAllForReprocess() {\n        int totalUpdated = 0;\n        int failedBatches = 0;\n        int failedCount = 0;\n        String runResult = \"success\";\n        Timer.Sample runSample = Timer.start(meterRegistry);\n\n        try {\n            int effectiveBatchSize = Math.max(1, markInitBatchSize);\n            Pageable pageable = PageRequest.of(0, effectiveBatchSize);\n\n            // Requirement: one transaction per update batch to avoid a huge long transaction.\n            TransactionTemplate batchTx = new TransactionTemplate(transactionManager);\n            // Always use a new transaction here so each batch update is independent:\n            // if one batch fails, only that batch rolls back and already committed batches stay committed.\n            batchTx.setPropagationBehavior(TransactionDefinition.PROPAGATION_REQUIRES_NEW);\n\n            long lastId = Long.MIN_VALUE;\n            while (true) {\n                List<Long> batchIds = entityRepository.findTopNIdsNeedMarkForReprocess(\n                        lastId, ReprocessState.INIT, pageable);\n                if (batchIds.isEmpty()) {\n                    break;\n                }\n\n                try {\n                    Integer updated = batchTx.execute(status ->\n                            entityRepository.markBatchForReprocess(batchIds, ReprocessState.INIT));\n                    int updatedRows = updated == null ? 0 : updated;\n                    totalUpdated += updatedRows;\n                } catch (Exception ex) {\n                    failedBatches++;\n                    failedCount += batchIds.size();\n                    log.error(\n                            \"markAllForReprocess: batch update failed for id range [{} - {}], batchSize={}, continue with next batch\",\n                            batchIds.get(0), batchIds.get(batchIds.size() - 1), batchIds.size(), ex\n                    );\n                }\n\n                // Move the cursor for