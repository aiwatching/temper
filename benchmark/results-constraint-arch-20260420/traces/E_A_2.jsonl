{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CSLG42MX5QrvX5DCVHLoTF","type":"tool_result","content":"1\tpackage com.fortinet.nac.ingestion.service.stages;\n2\t\n3\timport com.fasterxml.jackson.databind.ObjectMapper;\n4\timport com.fasterxml.jackson.databind.node.ObjectNode;\n5\timport com.fortinet.nac.common.enums.EntityProcessingCode;\n6\timport com.fortinet.nac.common.dto.EntityDTO;\n7\timport org.springframework.transaction.interceptor.TransactionAspectSupport;\n8\timport org.springframework.transaction.support.TransactionSynchronizationManager;\n9\t\n10\timport java.util.function.Function;\n11\t\n12\tpublic class StageExecutor {\n13\t\n14\t    private static final ObjectMapper mapper = new ObjectMapper();\n15\t\n16\t    public static ObjectNode execute(EntityDTO dto,\n17\t                                     Function<EntityDTO, ObjectNode> task) {\n18\t        try {\n19\t            return task.apply(dto);\n20\t        } catch (Exception ex) {\n21\t            // transaction roll back\n22\t            // Mark rollback-only ONLY if a tx is active\n23\t            try {\n24\t                if (TransactionSynchronizationManager.isActualTransactionActive()) {\n25\t                    TransactionAspectSupport.currentTransactionStatus().setRollbackOnly();\n26\t                }\n27\t            } catch (Exception ignore) {}\n28\t\n29\t            // Catch all exceptions and return a standardized response structure\n30\t            ObjectNode err = mapper.createObjectNode();\n31\t            err.put(\"code\", EntityProcessingCode.SYSTEM_ERROR);\n32\t            err.put(\"errMessage\", ex.getMessage());\n33\t            return err;\n34\t        }\n35\t    }\n36\t}\n37\t"}]},"parent_tool_use_id":"toolu_01SPCTUaXSmmm11PXF2zmWy8","session_id":"52431531-98c4-408a-846e-cbcca2319a2d","uuid":"651a6371-d639-4f17-b11c-ee1acbc17f95","timestamp":"2026-04-20T08:23:22.104Z"}
