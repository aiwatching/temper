{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UH8hXvbRrrMwTv9wCyumoy","type":"tool_result","content":"1\tpackage com.fortinet.nac.ingestion.service;\n2\t\n3\timport com.fortinet.nac.common.dto.IngestionRequest;\n4\timport com.fortinet.nac.common.dto.Pagination;\n5\timport com.fortinet.nac.common.enums.ReprocessState;\n6\timport com.fortinet.nac.ingestion.dto.EntityQueryDTO;\n7\timport com.fortinet.nac.ingestion.dto.MarkForReprocessResult;\n8\timport com.fortinet.nac.ingestion.entity.Entity;\n9\timport com.fortinet.nac.ingestion.repository.projection.EntityProcessLockInfo;\n10\t\n11\timport java.time.Duration;\n12\timport java.util.Collection;\n13\timport java.util.List;\n14\t\n15\tpublic interface EntityService {\n16\t\n17\t    Entity getById(Long id);\n18\t\n19\t    // MyBatis-Plus returns boolean because it operates on immediate SQL execution semantics.\n20\t    // Hibernate relies on transaction-level guarantees, where success or failure can\n21\t    // only be determined via exceptions.\n22\t    void save(Entity entity);\n23\t\n24\t    void saveBatch(Collection<Entity> entityList);\n25\t\n26\t    boolean isInterrupted(long entityId);\n27\t\n28\t    boolean setInterrupted(Long entityId, boolean interrupted);\n29\t\n30\t    Entity getEntity(Long id);\n31\t\n32\t    Entity getEntity(IngestionRequest req);\n33\t\n34\t    Pagination<Entity> queryFailedEntities(EntityQueryDTO req);\n35\t\n36\t    /**\n37\t     * Indicates whether the state machine has completed execution\n38\t     */\n39\t    boolean isProcessingFinished(Long entityId);\n40\t\n41\t    public boolean updateProcessingState(Entity fresh);\n42\t\n43\t    List<Entity> findStuckEntities(Duration staleThreshold, int maxCount);\n44\t\n45\t    MarkForReprocessResult markAllForReprocess();\n46\t\n47\t    List<Long> findTopNIdsByReprocessState(ReprocessState state, int limit);\n48\t\n49\t    EntityProcessLockInfo findProcessLockInfoById(Long id);\n50\t\n51\t    boolean claimInitEntityForReprocess(Long id);\n52\t\n53\t    boolean updateReprocessStateById(Long id, ReprocessState state);\n54\t}\n55\t"}]},"parent_tool_use_id":"toolu_01XTMSB51anBCfRx3H5DwZHs","session_id":"96f50260-dc60-4a75-a501-57c5af917508","uuid":"82825416-a403-4edc-a39d-362ac1bc03c7","timestamp":"2026-04-20T08:17:33.051Z"}
