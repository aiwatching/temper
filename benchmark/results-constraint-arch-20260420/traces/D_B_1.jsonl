on.class)\n39\t@EnabledIfSystemProperty(named = \"runTestContainerInDev\", matches = \"true\")\n40\tpublic class PolicyReprocessJobE2ETest {\n41\t\n42\t    @BeforeAll\n43\t    static void initSchema() throws Exception {\n44\t        List<String> scripts = List.of(\"sql/classification_test_ddl.sql\", \"sql/entity.sql\");\n45\t\n46\t        try (Connection conn = DriverManager.getConnection(\n47\t                mariadb.getJdbcUrl(), \"root\", \"dummy\")) {\n48\t            for (String script : scripts) {\n49\t                InputStream is = PolicyReprocessJobE2ETest.class.getClassLoader()\n50\t                    .getResourceAsStream(script);\n51\t\n52\t                Assertions.assertNotNull(is);\n53\t\n54\t                String ddl = new String(is.readAllBytes());\n55\t\n56\t                for (String sql : ddl.split(\";\")) {\n57\t                    sql = sql.trim();\n58\t                    if (!sql.isEmpty()) {\n59\t                        conn.createStatement().execute(sql);\n60\t                    }\n61\t                }\n62\t            }\n63\t        }\n64\t    }\n65\t\n66\t    // Redis\n67\t    @Container\n68\t    static GenericContainer<?> redis = new GenericContainer<>(\"redis:7.2.4\")\n69\t            .withExposedPorts(6379);\n70\t\n71\t    // MariaDB\n72\t    @Container\n73\t    static MariaDBContainer<?> mariadb = new MariaDBContainer<>(\"mariadb:10.7.8\")\n74\t            .withDatabaseName(\"bsc\")\n75\t            .withUsername(\"root\")\n76\t            .withPassword(\"dummy\");\n77\t\n78\t    @DynamicPropertySource\n79\t    static void injectProps(DynamicPropertyRegistry registry) {\n80\t        // Redis config overrides\n81\t        registry.add(\"spring.redis.host\", redis::getHost);\n82\t        registry.add(\"spring.redis.port\", redis::getFirstMappedPort);\n83\t        registry.add(\"spring.redis.timeout\", () -> \"15000\");\n84\t\n85\t        // Database config overrides\n86\t        registry.add(\"spring.datasource.url\", mariadb::get