{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TX2TUMPpFMQvhnwaHiDURp","type":"tool_result","content":"1\tpackage com.fortinet.nac.ingestion.controller;\n2\t\n3\timport com.fortinet.nac.common.Constants;\n4\timport com.fortinet.nac.common.dto.IngestionRequest;\n5\timport com.fortinet.nac.common.dto.ResultDTO;\n6\timport com.fortinet.nac.common.redisstream.RedisStreamProducer;\n7\timport com.fortinet.nac.ingestion.registry.IngestionCallbackRegistry;\n8\t\n9\timport lombok.RequiredArgsConstructor;\n10\timport lombok.extern.slf4j.Slf4j;\n11\timport org.slf4j.MDC;\n12\timport org.springframework.beans.factory.annotation.Autowired;\n13\timport org.springframework.beans.factory.annotation.Qualifier;\n14\timport org.springframework.beans.factory.annotation.Value;\n15\timport org.springframework.validation.annotation.Validated;\n16\timport org.springframework.web.bind.annotation.*;\n17\timport reactor.core.publisher.Mono;\n18\timport reactor.core.scheduler.Schedulers;\n19\t\n20\timport java.time.Duration;\n21\timport java.util.UUID;\n22\timport java.util.concurrent.*;\n23\t\n24\t@RestController\n25\t@RequestMapping(\"/api/v1/ingestion\")\n26\t@RequiredArgsConstructor\n27\t@Slf4j\n28\tpublic class IngestionController {\n29\t\n30\t    private final RedisStreamProducer producer;\n31\t    private final IngestionCallbackRegistry callbackRegistry;\n32\t\n33\t    @Autowired\n34\t    @Qualifier(\"nettyOffloadExecutor\")\n35\t    private ExecutorService nettyOffloadExecutor;\n36\t\n37\t    @Value(\"${ingestion.response-timeout:60}\")\n38\t    private int responseTimeout;\n39\t\n40\t    private final int HTTP_INTERNAL_SERVER_ERROR = 500;\n41\t\n42\t    @PostMapping(\"/events\")\n43\t    public Mono<ResultDTO<?>> ingestEvent(@RequestBody @Validated IngestionRequest req) {\n44\t\n45\t        return Mono.deferContextual(ctx -> {\n46\t\n47\t            // Step 1: prepare request\n48\t            req.setRequestId(generateRequestId());\n49\t            req.setAsync(false);\n50\t\n51\t            String traceId = ctx.getOrDefault(Constants.TRACE_ID, generateRequestId());\n52\t            req.setTraceId(traceId);\n53\t\n54\t            // put traceId into MDC for current thread so logback [%X{traceId}] works\n55\t            try (MDC.MDCCloseable ignored = MDC.putCloseable(Constants.TRACE_ID, traceId)) {\n56\t\n57\t                log.info(\"REST ingestion request arrived: requestId={}\", req.getRequestId());\n58\t\n59\t                // Step 2: register callback future\n60\t                CompletableFuture<ResultDTO<?>> future =\n61\t                    callbackRegistry.register(req.getRequestId());\n62\t\n63\t                // Add a timeout to the future itself to ensure the registry does not have memory leak.\n64\t                //\n65\t                // If the internal processing never calls callbackRegistry.complete(...)\n66\t                // (e.g., consumer crash, message loss, or the message stays pending forever),\n67\t                // the registry would otherwise leak memory.\n68\t                future.orTimeout(responseTimeout, TimeUnit.SECONDS)\n69\t                        .whenComplete((r, e) -> callbackRegistry.unregister(req.getRequestId()));\n70\t\n71\t                // Step 3: publish message\n72\t                boolean ok = producer.sendEvent(\n73\t                    Constants.RedisStream.INGESTION_INTERNAL_STREAM_KEY, req);\n74\t                if (!ok) {\n75\t                    callbackRegistry.unregister(req.getRequestId());\n76\t                    return Mono.just(ResultDTO.error(HTTP_INTERNAL_SERVER_ERROR, \"failed to publish message\"));\n77\t                }\n78\t\n79\t                // wait for internal consumer to finish future\n80\t                return Mono.fromFuture(future);\n81\t            }\n82\t        })\n83\t\n84\t        // Move all logic inside the defer block onto nettyOffloadExecutor thread pool to\n85\t        // avoid blocking the Netty event loop.\n86\t        .subscribeOn(Schedulers.fromExecutor(nettyOffloadExecutor))\n87\t        .onErrorResume(e -> {\n88\t            // unwrap CompletionException / ExecutionException\n89\t            Throwable t = e;\n90\t            if (t instanceof CompletionException || t instanceof ExecutionException) {\n91\t                if (t.getCause() != null) t = t.getCause();\n92\t            }\n93\t            if (t instanceof TimeoutException) {\n94\t                return Mono.just(ResultDTO.success(\"Request received but still processing\", req.getTraceId()));\n95\t            }\n96\t            return Mono.just(ResultDTO.error(HTTP_INTERNAL_SERVER_ERROR, \"internal error: \" + e.getMessage()));\n97\t        })\n98\t        .doFinally(sig -> MDC.remove(Constants.TRACE_ID));\n99\t    }\n100\t\n101\t\n102\t    @GetMapping(\"health-check\")\n103\t    public String healthCheck() {\n104\t        return \"OK\";\n105\t    }\n106\t\n107\t    private String generateRequestId() {\n108\t        return UUID.randomUUID().toString().replace(\"-\", \"\").substring(0, 16);\n109\t    }\n110\t\n111\t    // used for debugging\n112\t    private void logThreadPoolStats() {\n113\t        if (nettyOffloadExecutor instanceof ThreadPoolExecutor) {\n114\t            ThreadPoolExecutor executor =\n115\t                    (ThreadPoolExecutor) nettyOffloadExecutor;\n116\t\n117\t            log.info(\n118\t                    \"IngestionBlockPool stats: core={}, max={}, poolSize={}, active={}, queueSize={}\",\n119\t                    executor.getCorePoolSize(),\n120\t                    executor.getMaximumPoolSize(),\n121\t                    executor.getPoolSize(),\n122\t                    executor.getActiveCount(),\n123\t                    executor.getQueue().size()\n124\t            );\n125\t        }\n126\t    }\n127\t}\n128\t"}]},"parent_tool_use_id":"toolu_01XTMSB51anBCfRx3H5DwZHs","session_id":"96f50260-dc60-4a75-a501-57c5af917508","uuid":"010cd67c-63b9-4478-9908-bf01395c9103","timestamp":"2026-04-20T08:17:54