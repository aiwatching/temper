{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BUBfuwvRqvPJiDK5PdaxcY","type":"tool_result","content":"1\tpackage com.fortinet.nac.ingestion.controller;\n2\t\n3\timport com.fortinet.nac.common.dto.ResultDTO;\n4\timport com.fortinet.nac.ingestion.dto.MarkForReprocessResponse;\n5\timport com.fortinet.nac.ingestion.dto.MarkForReprocessResult;\n6\timport com.fortinet.nac.ingestion.job.event.PolicyReprocessRequestedEvent;\n7\timport com.fortinet.nac.ingestion.service.EntityService;\n8\timport lombok.RequiredArgsConstructor;\n9\timport lombok.extern.slf4j.Slf4j;\n10\timport org.springframework.context.ApplicationEventPublisher;\n11\timport org.springframework.web.bind.annotation.PostMapping;\n12\timport org.springframework.web.bind.annotation.RequestMapping;\n13\timport org.springframework.web.bind.annotation.RestController;\n14\t\n15\t@RestController\n16\t@RequestMapping(\"/api/v1/policy\")\n17\t@RequiredArgsConstructor\n18\t@Slf4j\n19\tpublic class PolicyController {\n20\t\n21\t    private final EntityService entityService;\n22\t    private final ApplicationEventPublisher eventPublisher;\n23\t\n24\t    @PostMapping(\"/apply-existing-entities\")\n25\t    public ResultDTO<MarkForReprocessResponse> applyExistingEntities() {\n26\t        log.info(\"PolicyController: received request to apply policy to all existing entities\");\n27\t        long startNanos = System.nanoTime();\n28\t\n29\t        try {\n30\t            // Mark all entities' reprocessState as INIT.\n31\t            MarkForReprocessResult markResult = entityService.markAllForReprocess();\n32\t\n33\t            int count = markResult.getUpdatedCount();\n34\t            int failedCount = markResult.getFailedCount();\n35\t            if (count > 0) {\n36\t                // Trigger an immediate scan, while the scheduled job remains as fallback.\n37\t                eventPublisher.publishEvent(new PolicyReprocessRequestedEvent(count, \"api\"));\n38\t            }\n39\t\n40\t            String status;\n41\t            String message;\n42\t            if (failedCount > 0 && count == 0) {\n43\t                status = \"FAILED\";\n44\t                message = String.format(\"Failed to mark entities, failedCount=%d\", failedCount);\n45\t                log.warn(\"PolicyController: mark entities failed, markedCount=0, failedCount={}, failedBatches={}\",\n46\t                        failedCount, markResult.getFailedBatches());\n47\t            } else if (failedCount > 0) {\n48\t                status = \"PARTIAL_SUCCESS\";\n49\t                message = String.format(\"Marked %d entities; %d entities failed during marking\", count, failedCount);\n50\t                log.warn(\"PolicyController: marked entities with partial failures, markedCount={}, failedCount={}, failedBatches={}\",\n51\t                        count, failedCount, markResult.getFailedBatches());\n52\t            } else {\n53\t                status = \"SUCCESS\";\n54\t                message = String.format(\"Marked %d entities for reprocessing\", count);\n55\t                log.info(\"PolicyController: successfully marked {} entities for reprocessing\", count);\n56\t            }\n57\t\n58\t            return ResultDTO.success(\n59\t                    MarkForReprocessResponse.builder()\n60\t                            .markedCount(count)\n61\t                            .failedBatches(markResult.getFailedBatches())\n62\t                            .failedCount(failedCount)\n63\t                            .timeCostMs((System.nanoTime() - startNanos) / 1_000_000)\n64\t                            .status(status)\n65\t                            .message(message)\n66\t                            .build());\n67\t        } catch (Exception e) {\n68\t            log.error(\"PolicyController: failed to mark entities for reprocessing\", e);\n69\t\n70\t            return ResultDTO.<MarkForReprocessResponse>builder()\n71\t                    .code(ResultDTO.DEFAULT_ERROR_CODE)\n72\t                    .errMsg(\"Failed with err=\" + e.getMessage())\n73\t                    .data(MarkForReprocessResponse.builder()\n74\t                            .markedCount(0)\n75\t                            .failedBatches(0)\n76\t                            .failedCount(0)\n77\t                            .timeCostMs((System.nanoTime() - startNanos) / 1_000_000)\n78\t                            .status(\"FAILED\")\n79\t                            .message(\"Failed to mark entities for reprocessing\")\n80\t                            .build())\n81\t                    .build();\n82\t        }\n83\t    }\n84\t}\n85\t"}]},"parent_tool_use_id":"toolu_01XTMSB51anBCfRx3H5DwZHs","session_id":"96f50260-dc60-4a75-a501-57c5af917508","uuid":"e832c813-dbbb-415a-826a-7133737d0402","timestamp":"2026-04-20T08:17:39.257Z"}
