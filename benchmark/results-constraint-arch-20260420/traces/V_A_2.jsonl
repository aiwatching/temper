{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CawsvXJNuiGjdAYKoBuFcB","type":"tool_result","content":"1\tserver:\n2\t  port: 8086\n3\t\n4\tspring:\n5\t  application:\n6\t    name: ingestion\n7\t\n8\t  redis:\n9\t    # host and port will be overridden by Testcontainers automatically\n10\t    host: localhost\n11\t    port: 6379\n12\t    timeout: 15000\n13\t\n14\t    # Redisson-specific configuration\n15\t    redisson:\n16\t      # Connection pool settings\n17\t      #\n18\t      # Maximum number of connections in Redis command connection pool.\n19\t      # Redisson doesn't distinguish max-idle, only cares about: maximum pool size and minimum keep-alive connections.\n20\t      #\n21\t      # Connection pool optimized for 24 stream consumers + business requests\n22\t      connection-pool-size: 96\n23\t\n24\t      # Minimum number of idle connections to retain in the pool.\n25\t      # Even if Redis isn't accessed for some time, keep at least this many connections ready.\n26\t      # Helps avoid \"cold start latency\" — no need to establish a new connection when requests resume.\n27\t      #\n28\t      # High QPS scenario, pre-warm 24 connections.\n29\t      # Keep a batch of connections resident in the pool, aligned with consumer count.\n30\t      connection-minimum-idle-size: 24\n31\t\n32\t      # Lettuce shares Pub/Sub and regular connections in the same pool (or a few independent).\n33\t      # But Redisson is different.\n34\t      #\n35\t      # Project currently doesn't use Pub/Sub.\n36\t      subscription-connection-pool-size: 8\n37\t      subscription-connection-minimum-idle-size: 2\n38\t\n39\t      # Redisson thread model:\n40\t      #      nettyThreads:\tIO threads\n41\t      #      threads:       \tRedisson workers (locks/callbacks/scheduling)\n42\t      # These two thread pools are global, not per-bean\n43\t      #\n44\t      # Recommended empirical values:\n45\t      #      nettyThreads ≈ CPU * 2\n46\t      #      threads ≈ CPU\n47\t      netty-threads: 16\n48\t      threads: 8\n49\t\n50\t      # Retry settings\n51\t      retry-attempts: 5\n52\t      retry-interval: 1000\n53\t\n54\t  datasource:\n55\t    url: jdbc:mariadb://localhost/bsc?localSocket=/var/lib/mysql/mysql.sock&zeroDateTimeBehavior=convertToNull&useUnicode=true&characterEncoding=UTF-8&CharSet=UTF-8\n56\t    username: root\n57\t    password: \"\"\n58\t    driver-class-name: org.mariadb.jdbc.Driver\n59\t\n60\t  jpa:\n61\t    hibernate:\n62\t      ddl-auto: validate\n63\t      naming:\n64\t        physical-strategy: org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl\n65\t    show-sql: false\n66\t    database-platform: org.hibernate.dialect.MariaDBDialect\n67\t\n68\tlogging:\n69\t  config: classpath:logback-spring.xml\n70\t\n71\t\n72\t\n73\t# =====================================================\n74\t# NAC Stream consumer & producer configuration (used by RedisStreamConsumerBase)\n75\t# =====================================================\n76\tnac:\n77\t  stream:\n78\t    max-length: 200000            # Maximum number of messages to retain in stream\n79\t    trim-enabled: true\n80\t    trim-every-n-writes: 1000\n81\t\n82\t    internal:\n83\t      poll-timeout-ms: 1000             # to avoid busy poll\n84\t      message-batch-size-per-poll: 20   # Too large batches will increase p95/max (worse tail latency).\n85\t      redis-consumer-count: 16\n86\t      worker-thread-pool-size: 32\n87\t    external:\n88\t      poll-timeout-ms: 1000             # to avoid busy poll\n89\t      message-batch-size-per-poll: 50\n90\t      redis-consumer-count: 8\n91\t      worker-thread-pool-size: 8\n92\t\n93\t    consume-max-retry: 3              # Max retry attempts on message consumption failure\n94\t    create-group-include-history: true  # Include historical messages when creating group during tests\n95\t    pending:\n96\t      idle-threshold-ms: 10000        # Consider stuck if not ACKed within 10 seconds\n97\t      scan-interval-ms: 5000          # Scan pending messages every 5 seconds\n98\t      claim-batch-size: 10            # Number of messages to claim per XPENDING batch\n99\t\n100\t\n101\t# =====================================================\n102\t# Ingestion Controller Reactive Netty Config\n103\t# =====================================================\n104\tingestion:\n105\t    recovery:\n106\t      enabled: true\n107\t      stale-threshold-seconds: 80\n108\t      fixed-delay-ms: 30000\n109\t      batch-size: 2000\n110\t      rate-limit-per-second: 100\n111\t      async:\n112\t        core-size: 4\n113\t        max-size: 16\n114\t        queue-capacity: 100\n115\t        keep-alive-seconds: 60\n116\t    reactive:\n117\t      thread-pool:\n118\t        core-size: 30\n119\t        max-size: 300\n120\t        queue-capacity: 10000\n121\t        keep-alive-seconds: 60\n122\t\n123\t# =====================================================\n124\t# Metrics\n125\t# =====================================================\n126\tmanagement:\n127\t  endpoints:\n128\t    web:\n129\t      exposure:\n130\t        # /metrics is for: JVM / thread pools / custom metrics\n131\t        include: health,info,prometheus,metrics\n132\t  metrics:\n133\t    distribution:\n134\t      # Only enable histogram for lock-hold metric (not global),\n135\t      # so we can compute p95/p99 from *_bucket while keeping overhead low.\n136\t      percentiles-histogram:\n137\t        policy_reproc_lock_hold_seconds: true\n138\t      # Histogram bucket lower bound for fine-grained range.\n139\t      # Values below 1ms are still counted (not dropped), but won't be over-segmented.\n140\t      minimum-expected-value:\n141\t        policy_reproc_lock_hold_seconds: 1ms\n142\t      # Histogram bucket upper bound for fine-grained range.\n143\t      # Values above 60s are still counted (not dropped), and fall into top bucket(s)\n144\t      # instead of creating more detailed buckets at very large durations.\n145\t      maximum-expected-value:\n146\t        policy_reproc_lock_hold_seconds: 60s\n147\t\n148\t# =====================================================\n149\t# Policy Reprocess Job Configuration\n150\t# =====================================================\n151\tpolicy:\n152\t  reprocess:\n153\t    # 1. producer side\n154\t    mark-init-batch-size: 1000\n155\t\n156\t    # 2. cron job side\n157\t    scan-interval-ms: 30000\n158\t    scan-batch-size: 200\n159\t    max-candidates-per-scan: 2000\n160\t    scan-lock-ttl-seconds: 900\n161\t    rate-limit-per-second: 100\n162\t\n163\t    # listener thread pool: handles PolicyReprocessRequestedEvent trigger\n164\t    listener:\n165\t      core-size: 1\n166\t      max-size: 2\n167\t      queue-capacity: 100\n168\t      keep-alive-seconds: 60\n169\t\n170\t    # job thread pool: executes per-entity reprocess tasks inside each scan batch\n171\t    job:\n172\t      core-size: 8\n173\t      max-size: 16\n174\t      queue-capacity: 32\n175\t      keep-alive-seconds: 60\n176\t"}]},"parent_tool_use_id":"toolu_01Nr6sfbteVD7ZXywcyenULC","session_id":"a33d1a26-027d-47f2-884a-b3de9e29e673","uuid":"af46a7da-786b-4805-a8e8-150c7e87c552","timestamp":"2026-04-20T08:20:09.830Z"}
