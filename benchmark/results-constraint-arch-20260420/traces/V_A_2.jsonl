{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018ERE83J8RAcpGjR8M2WjFg","type":"tool_result","content":"1\tpackage com.fortinet.nac.ingestion.controller;\n2\t\n3\timport com.fortinet.nac.common.dto.Pagination;\n4\timport com.fortinet.nac.common.dto.ResultDTO;\n5\timport com.fortinet.nac.common.enums.ReprocessState;\n6\timport com.fortinet.nac.ingestion.dto.EntityQueryDTO;\n7\timport com.fortinet.nac.ingestion.dto.EntityStateDisplayDTO;\n8\timport com.fortinet.nac.ingestion.entity.Entity;\n9\timport com.fortinet.nac.ingestion.service.EntityService;\n10\t\n11\timport org.springframework.web.bind.annotation.*;\n12\t\n13\timport javax.annotation.Resource;\n14\t\n15\t@RestController\n16\t@RequestMapping(\"/api/v1/entities\")\n17\tpublic class EntityController {\n18\t\n19\t    @Resource\n20\t    private EntityService entityService;\n21\t\n22\t    @PostMapping(\"/query\")\n23\t    public ResultDTO<Pagination<Entity>> queryFailedEntities(@RequestBody EntityQueryDTO req) {\n24\t        Pagination<Entity> page = entityService.queryFailedEntities(req);\n25\t        return ResultDTO.success(page);\n26\t    }\n27\t\n28\t    @GetMapping(\"/{id}\")\n29\t    public Entity getEntity(@PathVariable Long id) {\n30\t        return entityService.getById(id);\n31\t    }\n32\t\n33\t    @GetMapping(\"/{id}/display-status\")\n34\t    public ResultDTO<EntityStateDisplayDTO> getEntityDisplayStatus(@PathVariable Long id) {\n35\t        Entity entity = entityService.getById(id);\n36\t        if (entity == null) {\n37\t            return (ResultDTO<EntityStateDisplayDTO>) ResultDTO.error(\"Entity not found\");\n38\t        }\n39\t\n40\t        EntityStateDisplayDTO dto = new EntityStateDisplayDTO();\n41\t        dto.setId(entity.getId());\n42\t        dto.setType(entity.getType().toString());\n43\t        dto.setHostIdentity(entity.getHostIdentity());\n44\t        dto.setUserIdentity(entity.getUserIdentity());\n45\t        dto.setProcessingStage(entity.getProcessingStag