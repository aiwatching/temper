{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E9te844hpXk7VwEzGFNLcr","type":"tool_result","content":"1\tpackage com.fortinet.nac.ingestion.controller;\n2\t\n3\timport com.fortinet.nac.common.dto.Pagination;\n4\timport com.fortinet.nac.common.dto.ResultDTO;\n5\timport com.fortinet.nac.common.enums.ReprocessState;\n6\timport com.fortinet.nac.ingestion.dto.EntityQueryDTO;\n7\timport com.fortinet.nac.ingestion.dto.EntityStateDisplayDTO;\n8\timport com.fortinet.nac.ingestion.entity.Entity;\n9\timport com.fortinet.nac.ingestion.service.EntityService;\n10\t\n11\timport org.springframework.web.bind.annotation.*;\n12\t\n13\timport javax.annotation.Resource;\n14\t\n15\t/**\n16\t * TEMPER-CONSTRAINT: This controller must NOT reference repository classes directly.\n17\t *   All data access must go through an @Service layer class.\n18\t *   Reason: Layered architecture contract — repository-direct access from controllers:\n19\t *     - bypasses transaction boundaries defined in @Service (risk of partial writes)\n20\t *     - sidesteps business validation (tenant scoping, audit logging, DTO conversion)\n21\t *     - makes refactors harder — see MIG-2024 tech debt ticket\n22\t *   Rule:\n23\t *     - Do not import com.fortinet.nac.ingestion.repository.*\n24\t *     - Do not inject any *Repository bean into this controller.\n25\t *     - If a new data access path is needed, add a method to the appropriate\n26\t *       @Service class; do not reach into the repository from here.\n27\t *   If you believe this rule needs an exception, talk to platform team first.\n28\t *   See MIG-2024, commit e5f0a2c.\n29\t */\n30\t@RestController\n31\t@RequestMapping(\"/api/v1/entities\")\n32\tpublic class EntityController {\n33\t\n34\t    @Resource\n35\t    private EntityService entityService;\n36\t\n37\t    @PostMapping(\"/query\")\n38\t    public ResultDTO<Pagination<Entity>> queryFailedEntities(@RequestBody EntityQueryDTO req) {\n39\t        Pagination<Entity> page = entityService.queryFailedEntities(req);\n40\t        return ResultDTO.success(page);\n41\t    }\n42\t\n43\t    @GetMapping(\"/{id}\")\n44\t    public Entity getEntity(@PathVariable Long id) {\n45\t        return entityService.getById(id);\n46\t    }\n47\t\n48\t    @GetMapping(\"/{id}/display-status\")\n49\t    public ResultDTO<EntityStateDisplayDTO> getEntityDisplayStatus(@PathVariable Long id) {\n50\t        Entity entity = entityService.getById(id);\n51\t        if (entity == null) {\n52\t            return (ResultDTO<EntityStateDisplayDTO>) ResultDTO.error(\"Entity not found\");\n53\t        }\n54\t\n55\t        EntityStateDisplayDTO dto = new EntityStateDisplayDTO();\n56\t        dto.setId(entity.getId());\n57\t        dto.setType(entity.getType().toString());\n58\t        dto.setHostIdentity(entity.getHostIdentity());\n59\t        dto.setUserIdentity(entity.getUserIdentity());\n60\t        dto.setProcessingStage(entity.getProcessingStage());\n61\t        dto.setProcessingCode(entity.getProcessingCode());\n62\t        dto.setUpdatedAt(entity.getUpdatedAt());\n63\t\n64\t        // Map display status from reprocessState and processingStage.\n65\t        String displayStatus = mapToDisplayStatus(entity);\n66\t        dto.setDisplayStatus(displayStatus);\n67\t\n68\t        return ResultDTO.success(dto);\n69\t    }\n70\t\n71\t    private String mapToDisplayStatus(Entity entity) {\n72\t        ReprocessState reprocessState = entity.getReprocessState();\n73\t        if (reprocessState == null) {\n74\t            reprocessState = ReprocessState.NONE;\n75\t        }\n76\t\n77\t        switch (reprocessState) {\n78\t            case INIT:\n79\t                return \"init\";\n80\t            case RUNNING:\n81\t                return \"running\";\n82\t            case SUCCESS:\n83\t                // Count as enforced only when reprocessState=SUCCESS, processingStage=ENFORCED, and processingCode=0.\n84\t                if (\"ENFORCED\".equals(entity.getProcessingStage()) &&\n85\t                    (entity.getProcessingCode() == null || entity.getProcessingCode() == 0)) {\n86\t                    return \"enforced\";\n87\t                } else {\n88\t                    return \"failed\";\n89\t                }\n90\t            case FAILED:\n91\t                return \"failed\";\n92\t            case NONE:\n93\t            default:\n94\t                // If reprocessState is missing, derive display status directly from processingStage.\n95\t                if (\"ENFORCED\".equals(entity.getProcessingStage()) &&\n96\t                    (entity.getProcessingCode() == null || entity.getProcessingCode() == 0)) {\n97\t                    return \"enforced\";\n98\t                } else {\n99\t                    return entity.getProcessingStage() != null ? entity.getProcessingStage().toLowerCase() : \"unknown\";\n100\t                }\n101\t        }\n102\t    }\n103\t}\n104\t"}]},"parent_tool_use_id":"toolu_019ksR8i1hJHU7bmXsRvXfK2","session_id":"9a07d312-a44d-4996-81a0-f9eb8be41d48","uuid":"f58c24ad-92e8-4edf-b565-1d1f3193bd44","timestamp":"2026-04-20T08:28:05.408Z"}
