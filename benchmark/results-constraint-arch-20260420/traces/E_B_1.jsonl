{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B8UiNXoyFtPN9FZdg4Jdv8","type":"tool_result","content":"1\tpackage com.fortinet.nac.ingestion.service;\n2\t\n3\timport com.fortinet.nac.common.dto.UserAttribute;\n4\timport com.fortinet.nac.common.dto.HostAttribute;\n5\timport com.fortinet.nac.common.dto.DynamicClientAttribute;\n6\timport com.fortinet.nac.ingestion.dto.FingerprintRequestDTO;\n7\timport com.fortinet.nac.common.enums.EntityType;\n8\timport com.fortinet.nac.ingestion.entity.DynamicClient;\n9\timport com.fortinet.nac.ingestion.entity.HostRecord;\n10\timport com.fortinet.nac.ingestion.entity.UserRecord;\n11\timport com.fortinet.nac.ingestion.util.EntityUtil;\n12\timport com.fortinet.nac.ingestion.bo.HostRecordConverter;\n13\timport com.fortinet.nac.ingestion.bo.UserRecordConverter;\n14\timport com.fortinet.nac.ingestion.bo.DynamicClientConverter;\n15\t\n16\timport lombok.RequiredArgsConstructor;\n17\timport org.springframework.stereotype.Service;\n18\t\n19\timport java.util.*;\n20\t\n21\t@Service\n22\t@RequiredArgsConstructor\n23\tpublic class FingerprintServiceImpl implements FingerprintService {\n24\t\n25\t    private final HostRecordService hostRecordService;\n26\t    private final UserRecordService userRecordService;\n27\t    private final DynamicClientService dynamicClientService;\n28\t\n29\t    @Override\n30\t    public String buildFingerprint(FingerprintRequestDTO req) {\n31\t\n32\t        EntityType type = EntityType.valueOf(req.getEntityType().toUpperCase());\n33\t\n34\t        // Build Host Attribute / DynamicClientAttribute\n35\t        HostAttribute hostAttr = null;\n36\t        if (req.getHostId() != null) {\n37\t            HostRecord h = hostRecordService.getById(req.getHostId());\n38\t            if (h != null) {\n39\t                hostAttr = HostRecordConverter.toHostAttribute(h);\n40\t            }\n41\t        }\n42\t\n43\t        DynamicClientAttribute dcAttr = null;\n44\t        if (req.getAdapterId() != null) {\n45\t            DynamicClient d = dynamicClientService.getById(req.getAdapterId());\n46\t            if (d != null) {\n47\t                dcAttr = DynamicClientConverter.toAttribute(d);\n48\t            }\n49\t        }\n50\t\n51\t        List<String> includes = buildIncludeFields(req);\n52\t\n53\t        // HOST\n54\t        if (type == EntityType.HOST) {\n55\t            return EntityUtil.calcFingerprintWithFields(\n56\t                    hostAttr,\n57\t                    dcAttr,\n58\t                    includes\n59\t            );\n60\t        }\n61\t\n62\t        // USER_HOST_BINDING\n63\t        UserAttribute userAttr = null;\n64\t        if (req.getUserId() != null) {\n65\t            UserRecord u = userRecordService.getById(req.getUserId());\n66\t            if (u != null) {\n67\t                userAttr = UserRecordConverter.toUserAttribute(u);\n68\t            }\n69\t        }\n70\t\n71\t        return EntityUtil.calcFingerprintWithFields(\n72\t                userAttr,\n73\t                hostAttr,\n74\t                dcAttr,\n75\t                includes\n76\t        );\n77\t    }\n78\t\n79\t    /**\n80\t     * generate includeFields = [\"user.xxx\", \"host.xxx\", \"dc.xxx\"]\n81\t     */\n82\t    private List<String> buildIncludeFields(FingerprintRequestDTO req) {\n83\t        List<String> includes = new ArrayList<>();\n84\t\n85\t        if (req.getUserFields() != null) {\n86\t            req.getUserFields().forEach(f -> includes.add(\"user.\" + f));\n87\t        }\n88\t\n89\t        if (req.getHostFields() != null) {\n90\t            req.getHostFields().forEach(f -> includes.add(\"host.\" + f));\n91\t        }\n92\t\n93\t        if (req.getDynamicClientFields() != null) {\n94\t            req.getDynamicClientFields().forEach(f -> includes.add(\"dc.\" + f));\n95\t        }\n96\t\n97\t        return includes;\n98\t    }\n99\t}\n100\t"}]},"parent_tool_use_id":"toolu_01QfBEtv1fgXX1bHGg9bb9nz","session_id":"8dbd1af1-fcae-40b7-8568-cbe7877eafb8","