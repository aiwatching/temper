;\n46\t        executor.setRejectedExecutionHandler(new ThreadPoolExecutor.CallerRunsPolicy());\n47\t        executor.initialize();\n48\t        return executor;\n49\t    }\n50\t\n51\t    @Bean(\"policyReprocessJobExecutor\")\n52\t    public Executor policyReprocessJobExecutor() {\n53\t        int effectiveCoreSize = Math.max(1, jobCoreSize);\n54\t        int effectiveMaxSize = Math.max(effectiveCoreSize, jobMaxSize);\n55\t        ThreadPoolTaskExecutor executor = new ThreadPoolTaskExecutor();\n56\t        executor.setCorePoolSize(effectiveCoreSize);\n57\t        executor.setMaxPoolSize(effectiveMaxSize);\n58\t        executor.setQueueCapacity(jobQueueCapacity);\n59\t        executor.setKeepAliveSeconds(jobKeepAliveSeconds);\n60\t        executor.setThreadNamePrefix(\"policy-reprocess-job-\");\n61\t        executor.setRejectedExecutionHandler(new ThreadPoolExecutor.CallerRunsPolicy());\n62\t        executor.initialize();\n63\t        return executor;\n64\t    }\n65\t}\n66\t"}]},"parent_tool_use_id":"toolu_01QfBEtv1fgXX1bHGg9bb9nz","session_id":"8dbd1af1-fcae-40b7-8568-cbe7877eafb8","uuid":"d8631856-adf9-4822-9216-40d13e3c4f9a","timestamp":"2026-04-20T08:15:38.463Z"}
