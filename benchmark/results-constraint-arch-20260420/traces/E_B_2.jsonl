ync(false);\n50\t\n51\t            String traceId = ctx.getOrDefault(Constants.TRACE_ID, generateRequestId());\n52\t            req.setTraceId(traceId);\n53\t\n54\t            // put traceId into MDC for current thread so logback [%X{traceId}] works\n55\t            try (MDC.MDCCloseable ignored = MDC.putCloseable(Constants.TRACE_ID, traceId)) {\n56\t\n57\t                log.info(\"REST ingestion request arrived: requestId={}\", req.getRequestId());\n58\t\n59\t                // Step 2: register callback future\n60\t                CompletableFuture<ResultDTO<?>> future =\n61\t                    callbackRegistry.register(req.getRequestId());\n62\t\n63\t                // Add a timeout to the future itself to ensure the registry does not have memory leak.\n64\t                //\n65\t                // If the internal processing never calls callbackRegistry.complete(...)\n66\t                // (e.g., consumer crash, message loss, or the message stays pending forever),\n67\t                // the registry would otherwise leak memory.\n68\t                future.orTimeout(responseTimeout, TimeUnit.SECONDS)\n69\t                        .whenComplete((r, e) -> callbackRegistry.unregister(req.getRequestId()));\n70\t\n71\t                // Step 3: publish message\n72\t                boolean ok = producer.sendEvent(\n73\t                    Constants.RedisStream.INGESTION_INTERNAL_STREAM_KEY, req);\n74\t                if (!ok) {\n75\t                    callbackRegistry.unregister(req.getRequestId());\n76\t                    return Mono.just(ResultDTO.error(HTTP_INTERNAL_SERVER_ERROR, \"failed to publish message\"));\n77\t                }\n78\t\n79\t                // wait for internal consumer to finish future\n80\t                return Mono.fromFuture(future);\n81\t            }\n82\t        })\n83\t\n84\t        // Move all logic inside the defer block onto nettyOffloadExecutor thread pool to\n85\t        // avoid blocking the Netty event loop.\n86\t        .subscribeOn(Schedulers.fromExecutor(nettyOffloadExecutor))\n87\t        .onErrorResume(e -> {\n88\t            // unwrap CompletionException / ExecutionException\n89\t            Throwable t = e;\n90\t            if (t instanceof CompletionException || t instanceof ExecutionException) {\n91\t                if (t.getCause() != null) t = t.getCause();\n92\t            }\n93\t            if (t instanceof TimeoutException) {\n94\t                return Mono.just(ResultDTO.success(\"Request received but still processing\", req.getTraceId()));\n95\t            }\n96\t            return Mono.just(ResultDTO.error(HTTP_INTERNAL_SERVER_ERROR, \"internal error: \" + e.getMessage()));\n97\t        })\n98\t        .doFinally(sig -> MDC.remove(Constants.TRACE_ID));\n99\t    }\n100\t"}]},"parent_tool_use_id":"toolu_01EQ7vUSkwcky8UsVzKt6d21","session_id":"72817261-387c-44a0-af20-4fa307df618d","uuid":"7bcab885-93f9-48c4-a840-63d346ff69bc","timestamp":"2026-04-20T08:29:53.113Z"}
