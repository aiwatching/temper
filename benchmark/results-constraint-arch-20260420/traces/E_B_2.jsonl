{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TTvUbA3RPYo8sEyhY3VW8r","type":"tool_result","content":"1\tpackage com.fortinet.nac.ingestion.config;\n2\t\n3\timport com.bsc.database.PersistenceSnowflakeIdGenerator;\n4\timport org.springframework.beans.factory.annotation.Value;\n5\timport org.springframework.context.annotation.Bean;\n6\timport org.springframework.context.annotation.Configuration;\n7\timport org.springframework.context.annotation.Primary;\n8\t\n9\t@Configuration(\"ingestionIdGeneratorConfig\")\n10\tpublic class IdGeneratorConfig {\n11\t\n12\t    @Bean(\"ingestionIdGenerator\")\n13\t    public PersistenceSnowflakeIdGenerator defaultIdGenerator(\n14\t        @Value(\"${id.generator.data-center-id:0}\") int dataCenterId,\n15\t        @Value(\"${id.generator.worker-id:0}\") int workerId,\n16\t        @Value(\"${id.generator.data-server-id:ingest}\") String dataServerId,\n17\t        @Value(\"${id.generator.interval-seconds:10}\") int intervalSeconds,\n18\t        @Value(\"${id.generator.module:7}\") int module,\n19\t        @Value(\"${id.generator.base-dir:/bsc/campusMgr/config}\") String baseDir\n20\t    ) {\n21\t        java.nio.file.Path path = java.nio.file.Paths.get(baseDir);\n22\t\n23\t        PersistenceSnowflakeIdGenerator.Manager.initDefaults(\n24\t            dataCenterId, workerId, dataServerId, intervalSeconds, module, path\n25\t        );\n26\t        return PersistenceSnowflakeIdGenerator.Manager.createIdGenerator();\n27\t    }\n28\t}\n29\t\n30\t"}]},"parent_tool_use_id":"toolu_01EQ7vUSkwcky8UsVzKt6d21","session_id":"72817261-387c-44a0-af20-4fa307df618d","uuid":"0f961a2e-93f3-4281-ad64-203112dbe02a","timestamp":"2026-04-20T08:29:55.988Z"}
