tring status;\n41\t            String message;\n42\t            if (failedCount > 0 && count == 0) {\n43\t                status = \"FAILED\";\n44\t                message = String.format(\"Failed to mark entities, failedCount=%d\", failedCount);\n45\t                log.warn(\"PolicyController: mark entities failed, markedCount=0, failedCount={}, failedBatches={}\",\n46\t                        failedCount, markResult.getFailedBatches());\n47\t            } else if (failedCount > 0) {\n48\t                status = \"PARTIAL_SUCCESS\";\n49\t                message = String.format(\"Marked %d entities; %d entities failed during marking\", count, failedCount);\n50\t                log.warn(\"PolicyController: marked entities with partial failures, markedCount={}, failedCount={}, failedBatches={}\",\n51\t                        count, failedCount, markResult.getFailedBatches());\n52\t            } else {\n53\t                status = \"SUCCESS\";\n54\t                message = String.format(\"Marked %d entities for reprocessing\", count);\n55\t                log.info(\"PolicyController: successfully marked {} entities for reprocessing\", count);\n56\t            }\n57\t\n58\t            return ResultDTO.success(\n59\t                    MarkForReprocessResponse.builder()\n60\t                            .markedCount(count)\n61\t                            .failedBatches(markResult.getFailedBatches())\n62\t                            .failedCount(failedCount)\n63\t                            .timeCostMs((System.nanoTime() - startNanos) / 1_000_000)\n64\t                            .status(status)\n65\t                            .message(message)\n66\t                            .build());\n67\t        } catch (Exception e) {\n68\t            log.error(\"PolicyController: failed to mark entities for reprocessing\", e);\n69\t\n70\t            return ResultDTO.<MarkForReprocessResponse>builder()\n71\t                    .code(ResultDTO.DEFAULT_ERROR_CODE)\n72\t                    .errMsg(\"Failed with err=\" + e.getMessage())\n73\t                    .data(MarkForReprocessResponse.builder()\n74\t                            .markedCount(0)\n75\t                            .failedBatches(0)\n76\t                            .failedCount(0)\n77\t                            .timeCostMs((System.nanoTime() - startNanos) / 1_000_000)\n78\t                            .status(\"FAILED\")\n79\t                            .message(\"Failed to mark entities for reprocessing\")\n80\t                            .build())\n81\t                    .build();\n82\t        }\n83\t    }\n84\t}\n85\t"}]},"parent_tool_use_id":null,"session_id":"f740dd01-4690-4d22-a717-b6b57116b679","uuid":"ae44cb85-28f3-44ea-91bf-bc6013c01259","timestamp":"2026-04-20T08:27:02.908Z","tool_use_result":{"type":"text","file":{"filePath":"/private/tmp/temper-arch/A/ingestion/src/main/java/com/fortinet/nac/ingestion/controller/PolicyController.java","content":"package com.fortinet.nac.ingestion.controller;\n\nimport com.fortinet.nac.common.dto.ResultDTO;\nimport com.fortinet.nac.ingestion.dto.MarkForReprocessResponse;\nimport com.fortinet.nac.ingestion.dto.MarkForReprocessResult;\nimport com.fortinet.nac.ingestion.job.event.PolicyReprocessRequestedEvent;\nimport com.fortinet.nac.ingestion.service.EntityService;\nimport lombok.RequiredArgsConstructor;\nimport lombok.extern.slf4j.Slf4j;\nimport org.springframework.context.ApplicationEventPublisher;\nimport org.springframework.web.bind.annotation.PostMapping;\nimport org.springframework.web.bind.annotation.RequestMapping;\nimport org.springframework.web.bind.annotation.RestController;\n\n@RestController\n@RequestMapping(\"/api/v1/policy\")\n@RequiredArgsConstructor\n@Slf4j\npublic class PolicyController {\n\n    private final EntityService entityService;\n    private final ApplicationEventPublisher eventPublisher;\n\n    @PostMapping(\"/apply-existing-entities\")\n    public ResultDTO<MarkForReprocessResponse> applyExistingEntities() {\n        log.info(\"PolicyController: received request to apply policy to all existing entities\");\n        long startNanos = System.nanoTime();\n\n        try {\n            // Mark all entities' reprocessState as INIT.\n            MarkForReprocessResult markResult = entityService.markAllForReprocess();\n\n            int count = markResult.getUpdatedCount();\n            int failedCount = markResult.getFailedCount();\n            if (count > 0) {\n                // Trigger an immediate scan, while the scheduled job remains as fallback.\n                eventPublisher.publishEvent(new PolicyReprocessRequestedEvent(count, \"api\"));\n            }\n\n            String status;\n            String message;\n            if (failedCount > 0 && count == 0) {\n                status = \"FAILED\";\n                message = String.format(\"Failed to mark entities, failedCount=%d\", failedCount);\n                log.warn(\"PolicyController: mark entities failed, markedCount=0, failedCount={}, failedBatches={}\",\n                        failedCount, markResult.getFailedBatches());\n            } else if (failedCount > 0) {\n                status = \"PARTIAL_SUCCESS\";\n                message = String.format(\"Marked %d entities; %d entities failed during marking\", count, failedCount);\n                log.warn(\"PolicyController: marked entities with partial failures, markedCount={}, failedCount={}, failedBatches={}\",\n                        count, failedCount, markResult.getFailedBatches());\n            } else {\n                status = \"SUCCESS\";\n                message = String.format(\"Marked %d entities for reprocessing\", count);\n                log.info(\"PolicyController: successfully marked {} entities for reprocessing\", count);\n            }\n\n            return ResultDTO.success(\n                    MarkForReprocessResponse.builder()\n                            .markedCount(count)\n                            .failedBatches(markResult.getFailedBatches())\n                            .failedCount(failedCount)\n                            .timeCostMs((System.nanoTime() - startNanos) / 1_000_000)\n                            .status(status)\n                            .message(message)\n                            .build());\n        } catch (Exception e) {\n            log.error(\"PolicyController: failed to mark entities for reprocessing\", e);\n\n            return ResultDTO.<MarkForReprocessResponse>builder()\n                    .code(ResultDTO.DEFAULT_ERROR_CODE)\n                    .errMsg(\"Failed with err=\" + e.getMessage())\n                    .data(MarkForReprocessResponse.builder()\n                            .markedCount(0)\n                            .failedBatches(0)\n                            .failedCount(0)\n                            .timeCostMs((System.nanoTime() - startNanos) / 1_000_000)\n                            .status(\"FAILED\")\n                            .message(\"Failed to mark entities for reprocessing\")\n                            .build())\n                    .build();\n        }\n    }\n}\n","numLines":85,"startLine":1,"totalLines":85}}}
