{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011cVzo3eXZXfEphDN5HWeYo","type":"tool_result","content":"1\tpackage com.fortinet.nac.ingestion.service;\n2\t\n3\timport com.fortinet.nac.common.dto.IngestionRequest;\n4\timport com.fortinet.nac.common.dto.Pagination;\n5\timport com.fortinet.nac.common.enums.ReprocessState;\n6\timport com.fortinet.nac.common.service.IdService;\n7\timport com.fortinet.nac.ingestion.dto.EntityQueryDTO;\n8\timport com.fortinet.nac.ingestion.dto.MarkForReprocessResult;\n9\timport com.fortinet.nac.ingestion.entity.Entity;\n10\timport com.fortinet.nac.common.enums.EntityType;\n11\timport com.fortinet.nac.ingestion.repository.EntityRepository;\n12\timport com.fortinet.nac.ingestion.repository.projection.EntityProcessLockInfo;\n13\timport io.micrometer.core.instrument.MeterRegistry;\n14\timport io.micrometer.core.instrument.Timer;\n15\timport lombok.RequiredArgsConstructor;\n16\timport lombok.extern.slf4j.Slf4j;\n17\timport org.springframework.beans.factory.annotation.Qualifier;\n18\timport org.springframework.beans.factory.annotation.Value;\n19\timport org.springframework.data.domain.*;\n20\timport org.springframework.data.jpa.domain.Specification;\n21\timport org.springframework.stereotype.Service;\n22\timport org.springframework.transaction.PlatformTransactionManager;\n23\timport org.springframework.transaction.TransactionDefinition;\n24\timport org.springframework.transaction.annotation.Propagation;\n25\timport org.springframework.transaction.annotation.Transactional;\n26\timport org.springframework.transaction.support.TransactionTemplate;\n27\t\n28\timport javax.annotation.PostConstruct;\n29\timport javax.persistence.criteria.Predicate;\n30\timport java.time.Duration;\n31\timport java.time.Instant;\n32\timport java.util.*;\n33\timport java.util.concurrent.atomic.AtomicInteger;\n34\t\n35\t@Slf4j\n36\t@Service\n37\t@RequiredArgsConstructor\n38\tpublic class EntityServiceImpl implements EntityService {\n39\t\n40\t    private final EntityRepository entityRepository;\n41\t\n42\t    @Qualifier(\"IngestionIdService\")\n43\t    private final IdService idService;\n44\t\n45\t    private final PlatformTransactionManager transactionManager;\n46\t    private final MeterRegistry meterRegistry;\n47\t    private final AtomicInteger markInitLastFailedBatches = new AtomicInteger(0);\n48\t\n49\t    @Value(\"${policy.reprocess.mark-init-batch-size:1000}\")\n50\t    private int markInitBatchSize;\n51\t\n52\t    @PostConstruct\n53\t    public void initMetrics() {\n54\t        meterRegistry.gauge(\"policy_reprocess_mark_init_last_failed_batches\", markInitLastFailedBatches);\n55\t    }\n56\t\n57\t    @Override\n58\t    public Entity getById(Long id) {\n59\t        return entityRepository.findById(id).orElse(null);\n60\t    }\n61\t\n62\t    @Override\n63\t    public void save(Entity entity) {\n64\t        if (entity.getId() == null) {\n65\t            entity.setId(idService.nextId());\n66\t        }\n67\t\n68\t        Instant now = Instant.now();\n69\t\n70\t        if (entity.getCreatedAt() == null) {\n71\t            entity.setCreatedAt(now);\n72\t        }\n73\t        if (entity.getUpdatedAt() == null) {\n74\t            entity.setUpdatedAt(now);\n75\t        }\n76\t\n77\t        entityRepository.save(entity);\n78\t    }\n79\t\n80\t    @Override\n81\t    public void saveBatch(Collection<Entity> entityList) {\n82\t        Instant now = Instant.now();\n83\t\n84\t        for (Entity e : entityList) {\n85\t            if (e.getId() == null) {\n86\t                e.setId(idService.nextId());\n87\t            }\n88\t\n89\t            if (e.getCreatedAt() == null) {\n90\t                e.setCreatedAt(now);\n91\t            }\n92\t            if (e.getUpdatedAt() == null) {\n93\t                e.setUpdatedAt(now);\n94\t            }\n95\t        }\n96\t        entityRepository.saveAll(entityList);\n97\t    }\n98\t\n99\t    public boolean isInterrupted(long entityId) {\n100\t        return entityRepository.findById(entityId)\n101\t                .map(Entity::isInterrupted)\n102\t                .orElse(false);\n103\t    }\n104\t\n105\t    // Use a separate transaction to guarantee the state update is committed,\n106\t    // even if the outer transaction fails or is rolled back.\n107\t    @Transactional(propagation = Propagation.REQUIRES_NEW)\n108\t    public boolean setInterrupted(Long entityId, boolean interrupted) {\n109\t        int rows = entityRepository.updateInterrupted(entityId, interrupted, Instant.now());\n110\t        if (rows == 0) {\n111\t            log.error(\"setInterrupted rows=0, id={}, interrupted={}\", entityId, interrupted);\n112\t            return false;\n113\t        }\n114\t        return true;\n115\t    }\n116\t\n117\t    public Entity getEntity(Long id) {\n118\t        return entityRepository.findById(id).orElse(null);\n119\t    }\n120\t\n121\t    /**\n122\t     * Query database based on entity type + identity\n123\t     */\n124\t    public Entity getEntity(IngestionRequest req) {\n125\t        String type = req.getEntityType();\n126\t\n127\t        // HOST\n128\t        if (\"HOST\".equalsIgnoreCase(type)) {\n129\t            String hostIdentity = req.getHostId() + \"_\" + req.getAdapterId();\n130\t            return entityRepository\n131\t                    .findFirstByTypeAndHostIdentity(EntityType.HOST, hostIdentity)\n132\t                    .orElse(null);\n133\t        }\n134\t\n135\t        // USER_HOST_BINDING\n136\t        String hostIdentity = req.getHostId() + \"_\" + req.getAdapterId();\n137\t        return entityRepository\n138\t                .findFirstByTypeAndHostIdentityAndUserIdentity(\n139\t                        EntityType.USER_HOST_BINDING, hostIdentity, req.getUserId()\n140\t                )\n141\t                .orElse(null);\n142\t    }\n143\t\n144\t    @Override\n145\t    public Pagination<Entity> queryFailedEntities(EntityQueryDTO req) {\n146\t\n147\t        Specification<Entity> spec = (root, query, cb) -> {\n148\t            List<Predicate> predicates = new ArrayList<>();\n149\t\n150\t            if (req.getStage() != null && !req.getStage().isEmpty()) {\n151\t                predicates.add(cb.equal(root.get(\"processingStage\"), req.getStage()));\n152\t            }\n153\t\n154\t            if (req.getCode() != null) {\n155\t                predicates.add(cb.equal(root.get(\"processingCode\"), req.getCode()));\n156\t            } else {\n157\t                predicates.add(cb.notEqual(root.get(\"processingCode\"), 0));\n158\t            }\n159\t\n160\t            return cb.and(predicates.toArray(new Predicate[0]));\n161\t        };\n162\t\n163\t        String sortKey = req.getSortKey();\n164\t        boolean asc = \"asc\".equalsIgnoreCase(req.getSortOrder());\n165\t\n166\t        if (sortKey == null || sortKey.isEmpty()) {\n167\t            sortKey = \"createdAt\";\n168\t        }\n169\t\n170\t        String sortProperty;\n171\t        switch (sortKey) {\n172\t            case \"processingStage\":\n173\t                sortProperty = \"processingStage\";\n174\t                break;\n175\t            case \"type\":\n176\t                sortProperty = \"type\";\n177\t                break;\n178\t            case \"createdAt\":\n179\t            default:\n180\t                sortProperty = \"createdAt\";\n181\t                break;\n182\t        }\n183\t\n184\t        Sort sort = Sort.by(asc ? Sort.Direction.ASC : Sort.Direction.DESC, sortProperty);\n185\t        Pageable pageable = PageRequest.of(\n186\t                Math.max(0, req.getPageNum() - 1),\n187\t                req.getPageSize(),\n188\t                sort\n189\t        );\n190\t\n191\t        Page<Entity> page = entityRepository.findAll(spec, pageable);\n192\t\n193\t        return Pagination.<Entity>builder()\n194\t                .list(page.getContent())\n195\t                .totalRecords(page.getTotalElements())\n196\t                .totalPages(page.getTotalPages())\n197\t                .pageNum(page.getNumber() + 1)\n198\t                .pageSize(page.getSize())\n199\t                .build();\n200\t    }\n201\t\n202\t    @Override\n203\t    public boolean isProcessingFinished(Long entityId) {\n204\t        Entity e = entityRepository.findById(entityId).orElse(null);\n205\t        if (e == null) {\n206\t            return true;\n207\t        }\n208\t\n209\t        if (\"ENFORCED\".equalsIgnoreCase(e.getProcessingStage())) {\n210\t            return true;\n211\t        }\n212\t\n213\t        // processingCode != 0: indicates failure and exit\n214\t        Integer code = e.getProcessingCode();\n215\t        return code != null && code != 0;\n216\t    }\n217\t\n218\t    @Override\n219\t    @Transactional(propagation = Propagation.REQUIRES_NEW)\n220\t    public boolean updateProcessingState(Entity fresh) {\n221\t        if (fresh == null || fresh.getId() == null) return false;\n222\t\n223\t        fresh.setUpdatedAt(Instant.now());\n224\t\n225\t        int rows = entityRepository.updateProcessingState(\n226\t                fresh.getId(),\n227\t                fresh.isInterrupted(),\n228\t                fresh.getAttributeFingerprint(),\n229\t                fresh.getProcessingStage(),\n230\t                fresh.getProcessingCode(),\n231\t                fresh.getLastReqVersion(),\n232\t                fresh.getProcessingResult(),\n233\t                fresh.getUpdatedAt()\n234\t        );\n235\t        if (rows == 0) log.error(\"updateProcessingState rows=0, id={}, stage={}\", fresh.getId(), fresh.getProcessingStage());\n236\t        return rows > 0;\n237\t    }\n238\t\n239\t    @Override\n240\t    public List<Entity> findStuckEntities(Duration staleThreshold, int maxCount) {\n241\t        Instant before = Instant.now().minus(staleThreshold);\n242\t        var pageable = PageRequest.of(0, maxCount);\n243\t\n244\t        Page<Entity> page = entityRepository.findStuckEntities(before, pageable);\n245\t        List<Entity> result = page.getContent();\n246\t        if (!result.isEmpty()) {\n247\t            log.info(\"findStuckEntities: found {} candidates before={}, threshold={}\",\n248\t                    result.size(), before, staleThreshold);\n249\t        }\n250\t        return result;\n251\t    }\n252\t\n253\t    // Mark entities that need reprocessing to INIT in batches, and return total updated rows.\n254\t    @Override\n255\t    public MarkForReprocessResult markAllForReprocess() {\n256\t        int totalUpdated = 0;\n257\t        int failedBatches = 0;\n258\t        int failedCount = 0;\n259\t        String runResult = \"success\";\n260\t        Timer.Sample runSample = Timer.start(meterRegistry);\n261\t\n262\t        try {\n263\t            int effectiveBatchSize = Math.max(1, markInitBatchSize);\n264\t            Pageable pageable = PageRequest.of(0, effectiveBatchSize);\n265\t\n266\t            // Requirement: one transaction per update batch to avoid a huge long transaction.\n267\t            TransactionTemplate batchTx = new TransactionTemplate(transactionManager);\n268\t            // Always use a new transaction here so each batch update is independent:\n269\t            // if one batch fails, only that batch rolls back and already committed batches stay committed.\n270\t            batchTx.setPropagationBehavior(TransactionDefinition.PROPAGATION_REQUIRES_NEW);\n271\t\n272\t            long lastId = Long.MIN_VALUE;\n273\t            while (true) {\n274\t                List<Long> batchIds = entityRepository.findTopNIdsNeedMarkForReprocess(\n275\t                        lastId, ReprocessState.INIT, pageable);\n276\t                if (batchIds.isEmpty()) {\n277\t                    break;\n278\t                }\n279\t\n280\t                try {\n281\t                    Integer updated = batchTx.execute(status ->\n282\t                            entityRepository.markBatchForReprocess(batchIds, ReprocessState.INIT));\n283\t                    int updatedRows = updated == null ? 0 : updated;\n284\t                    totalUpdated += updatedRows;\n285\t                } catch (Exception ex) {\n286\t                    failedBatches++;\n287\t                    failedCount += batchIds.size();\n288\t                    log.error(\n289\t                            \"markAllForReprocess: batch update failed for id range [{} - {}], batchSize={}, continue with next batch\",\n290\t                            batchIds.get(0), batchIds.get(batchIds.size() - 1), batchIds.size(), ex\n291\t                    );\n292\t                }\n293\t\n294\t                // Move the cursor forward even when one batch fails, to avoid getting stuck retrying the same batch.\n295\t                lastId = batchIds.get(batchIds.size() - 1);\n296\t\n297\t                // Last short page means this run has drained current backlog.\n298\t                if (batchIds.size() < effectiveBatchSize) {\n299\t                    break;\n300\t                }\n301\t            }\n302\t\n303\t            if (failedBatches > 0) {\n304\t                runResult = \"partial_failure\";\n305\t                log.warn(\"markAllForReprocess: completed with partial failures, updatedCount={}, failedBatches={}\",\n306\t                        totalUpdated, failedBatches);\n307\t            }\n308\t            return MarkForReprocessResult.builder()\n309\t                    .updatedCount(totalUpdated)\n310\t                    .failedBatches(failedBatches)\n311\t                    .failedCount(failedCount)\n312\t                    .build();\n313\t        } catch (Exception ex) {\n314\t            runResult = \"failed\";\n315\t            log.error(\"markAllForReprocess: failed unexpectedly, updatedCount={}, failedBatches={}\",\n316\t                    totalUpdated, failedBatches, ex);\n317\t            throw ex;\n318\t        } finally {\n319\t            markInitLastFailedBatches.set(failedBatches);\n320\t            runSample.stop(markInitRunTimeCost(runResult));\n321\t        }\n322\t    }\n323\t\n324\t    @Override\n325\t    public List<Long> findTopNIdsByReprocessState(ReprocessState state, int limit) {\n326\t        Pageable pageable = PageRequest.of(0, limit);\n327\t        return entityRepository.findTopNIdsByReprocessState(state, pageable);\n328\t    }\n329\t\n330\t    @Override\n331\t    public EntityProcessLockInfo findProcessLockInfoById(Long id) {\n332\t        return entityRepository.findProcessLockInfoById(id).orElse(null);\n333\t    }\n334\t\n335\t    @Override\n336\t    @Transactional(propagation = Propagation.REQUIRES_NEW)\n337\t    public boolean claimInitEntityForReprocess(Long id) {\n338\t        int rows = entityRepository.claimInitEntityForReprocess(id, Instant.now());\n339\t        return rows > 0;\n340\t    }\n341\t\n342\t    @Override\n343\t    @Transactional(propagation = Propagation.REQUIRES_NEW)\n344\t    public boolean updateReprocessStateById(Long id, ReprocessState state) {\n345\t        int rows = entityRepository.updateReprocessStateById(id, state, Instant.now());\n346\t        return rows > 0;\n347\t    }\n348\t\n349\t    private Timer markInitRunTimeCost(String result) {\n350\t        return Timer.builder(\"policy_reprocess_mark_init_run_seconds\")\n351\t                .tag(\"result\", result)\n352\t                .register(meterRegistry);\n353\t    }\n354\t}\n355\t"}]},"parent_tool_use_id":"toolu_01YYYKrvBpaorwFWK2cTBtHz","session_id":"f740dd01-4690-4d22-a717-b6b57116b679","uuid":"42f2ed29-a280-4c44-b688-ea9514817098","timestamp":"2026-04-20T08:25:52.322Z"}
