{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M7zmYjQpQUR7kFpqGRaT44","type":"tool_result","content":"1\tpackage com.fortinet.nac.ingestion.entity;\n2\t\n3\timport com.fasterxml.jackson.annotation.JsonRawValue;\n4\timport com.fasterxml.jackson.databind.annotation.JsonSerialize;\n5\timport com.fasterxml.jackson.databind.ser.std.ToStringSerializer;\n6\timport com.fortinet.nac.common.enums.EntityType;\n7\timport com.fortinet.nac.common.enums.ReprocessState;\n8\t\n9\timport lombok.*;\n10\t\n11\timport javax.persistence.*;\n12\timport java.time.Instant;\n13\timport java.time.LocalDateTime;\n14\t\n15\t@Data\n16\t@Builder\n17\t@NoArgsConstructor\n18\t@AllArgsConstructor\n19\t@javax.persistence.Entity\n20\t@Table(name = \"entities\")\n21\tpublic class Entity {\n22\t\n23\t    @Id\n24\t    @Column(name = \"id\", nullable = false)\n25\t    @JsonSerialize(using = ToStringSerializer.class)\n26\t    private Long id;\n27\t\n28\t    @Enumerated(EnumType.STRING)\n29\t    @Column(name = \"type\", nullable = false, length = 20)\n30\t    private EntityType type;\n31\t\n32\t    @Column(name = \"source\", nullable = false, length = 20)\n33\t    private String source;\n34\t\n35\t    @Column(name = \"user_id\", columnDefinition = \"char(36)\")\n36\t    private String userId;\n37\t\n38\t    @Column(name = \"host_id\", columnDefinition = \"char(36)\")\n39\t    private String hostId;\n40\t\n41\t    @Column(name = \"adapter_id\", columnDefinition = \"char(36)\")\n42\t    private String adapterId;\n43\t\n44\t    @Column(name = \"user_identity\", length = 255)\n45\t    private String userIdentity;\n46\t\n47\t    @Column(name = \"host_identity\", nullable = false, length = 255)\n48\t    private String hostIdentity;\n49\t\n50\t    @Column(name = \"binding_type\", length = 20)\n51\t    private String bindingType;\n52\t\n53\t    @Column(name = \"binding_start_time\")\n54\t    private LocalDateTime bindingStartTime;\n55\t\n56\t    @Column(name = \"binding_end_time\")\n57\t    private LocalDateTime bindingEndTime;\n58\t\n59\t    @Column(name = \"processing_stage\", length = 10)\n60\t    private String processingStage;\n61\t\n62\t    @Column(name = \"processing_code\")\n63\t    private Integer processingCode;\n64\t\n65\t    @Column(name = \"error_message\", length = 1024)\n66\t    private String errorMessage;\n67\t\n68\t    @JsonRawValue\n69\t    @Lob\n70\t    @Column(name = \"processing_result\")\n71\t    private String processingResult;\n72\t\n73\t    @Column(name=\"created_at\", nullable = false)\n74\t    private Instant createdAt;\n75\t\n76\t    @Column(name=\"updated_at\", nullable = false)\n77\t    private Instant updatedAt;\n78\t\n79\t    @Column(name = \"interrupted\", nullable = false)\n80\t    private boolean interrupted;\n81\t\n82\t    @Column(name = \"attribute_fingerprint\", nullable = false, length = 255)\n83\t    private String attributeFingerprint;\n84\t\n85\t    @Column(name = \"last_req_version\", nullable = false, length = 50)\n86\t    private String lastReqVersion;\n87\t\n88\t    @Enumerated(EnumType.STRING)\n89\t    @Column(name = \"reprocess_state\", length = 20, nullable = false)\n90\t    @Builder.Default\n91\t    private ReprocessState reprocessState = ReprocessState.NONE;\n92\t}\n93\t"}]},"parent_tool_use_id":"toolu_01YYYKrvBpaorwFWK2cTBtHz","session_id":"f740dd01-4690-4d22-a717-b6b57116b679","uuid":"d1d8bdf8-56b3-4bf2-ae05-db133f88aa4d","timestamp":"2026-04-20T08:25:54.930Z"}
