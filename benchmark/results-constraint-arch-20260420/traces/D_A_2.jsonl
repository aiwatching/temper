{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DgptC9XZk3955FKEqUo3kV","type":"tool_result","content":"1\tpackage com.fortinet.nac.ingestion.e2e;\n2\t\n3\timport com.fortinet.nac.ingestion.dto.EntityQueryDTO;\n4\timport com.fortinet.nac.ingestion.entity.Entity;\n5\timport com.fortinet.nac.common.enums.EntityType;\n6\timport com.fortinet.nac.ingestion.service.*;\n7\timport org.junit.jupiter.api.*;\n8\timport org.junit.jupiter.api.condition.EnabledIfSystemProperty;\n9\timport org.springframework.beans.factory.annotation.Autowired;\n10\timport org.springframework.boot.test.context.SpringBootTest;\n11\timport org.springframework.boot.web.server.LocalServerPort;\n12\timport org.springframework.http.MediaType;\n13\timport org.springframework.test.context.DynamicPropertyRegistry;\n14\timport org.springframework.test.context.DynamicPropertySource;\n15\timport org.springframework.test.web.reactive.server.WebTestClient;\n16\timport org.testcontainers.containers.GenericContainer;\n17\timport org.testcontainers.containers.MariaDBContainer;\n18\timport org.testcontainers.junit.jupiter.Container;\n19\timport org.testcontainers.junit.jupiter.Testcontainers;\n20\t\n21\timport java.io.InputStream;\n22\timport java.sql.Connection;\n23\timport java.sql.DriverManager;\n24\timport java.time.Duration;\n25\timport java.time.Instant;\n26\timport java.time.temporal.ChronoUnit;\n27\timport java.util.ArrayList;\n28\timport java.util.List;\n29\t\n30\t@Testcontainers\n31\t// Start a real HTTP server (Netty), listening on a random port (stored in 'port').\n32\t@SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)\n33\t@TestMethodOrder(MethodOrderer.OrderAnnotation.class)\n34\t@EnabledIfSystemProperty(named = \"runTestContainerInDev\", matches = \"true\")\n35\tpublic class EntityControllerE2ETest {\n36\t\n37\t    @BeforeAll\n38\t    static void initSchema() throws Exception {\n39\t        try (Connection conn = DriverManager.getConnection(\n40\t                mariadb.getJdbcUrl(), \"root\", \"dummy\")) {\n41\t\n42\t            InputStream is = EntityControllerE2ETest.class.getClassLoader()\n43\t                    .getResourceAsStream(\"sql/entity.sql\");\n44\t\n45\t            Assertions.assertNotNull(is);\n46\t\n47\t            String ddl = new String(is.readAllBytes());\n48\t\n49\t            for (String sql : ddl.split(\";\")) {\n50\t                sql = sql.trim();\n51\t                if (!sql.isEmpty()) {\n52\t                    conn.createStatement().execute(sql);\n53\t                }\n54\t            }\n55\t        }\n56\t    }\n57\t\n58\t    // Redis\n59\t    @Container\n60\t    static GenericContainer<?> redis = new GenericContainer<>(\"redis:7.2.4\")\n61\t            .withExposedPorts(6379);\n62\t\n63\t    // MariaDB\n64\t    @Container\n65\t    static MariaDBContainer<?> mariadb = new MariaDBContainer<>(\"mariadb:10.7.8\")\n66\t            .withDatabaseName(\"bsc\")\n67\t            .withUsername(\"root\")\n68\t            .withPassword(\"dummy\");\n69\t\n70\t    @DynamicPropertySource\n71\t    static void injectProps(DynamicPropertyRegistry registry) {\n72\t\n73\t        // Redis config overrides\n74\t        registry.add(\"spring.redis.host\", redis::getHost);\n75\t        registry.add(\"spring.redis.port\", redis::getFirstMappedPort);\n76\t\n77\t        // Database config overrides\n78\t        registry.add(\"spring.datasource.url\", mariadb::getJdbcUrl);\n79\t        registry.add(\"spring.datasource.username\", mariadb::getUsername);\n80\t        registry.add(\"spring.datasource.password\", mariadb::getPassword);\n81\t    }\n82\t\n83\t    @LocalServerPort\n84\t    int port;\n85\t\n86\t    @Autowired\n87\t    private WebTestClient webClient;\n88\t\n89\t    @Autowired\n90\t    private EntityService entityService;\n91\t\n92\t    @BeforeEach\n93\t    void setup() {\n94\t        webClient = webClient.mutate().responseTimeout(Duration.ofSeconds(30)).build();\n95\t    }\n96\t\n97\t    @Test\n98\t    void testEntityQueryApiE2E() {\n99\t\n100\t        List<Entity> batch = new ArrayList<>();\n101\t        for (int i = 3; i <= 30; i++) {\n102\t            Instant t = Instant.now().plus(i, ChronoUnit.HOURS);\n103\t\n104\t            Entity e = Entity.builder()\n105\t                    .type(EntityType.USER_HOST_BINDING)\n106\t                    .source(\"PORTAL\")\n107\t                    .userId(String.valueOf(i))\n108\t                    .hostId(String.valueOf(i))\n109\t                    .adapterId(String.valueOf(i))\n110\t                    .userIdentity(String.valueOf(i))\n111\t                    .hostIdentity(i + \"_\" + i)\n112\t                    .processingStage(\"PENDING\")\n113\t                    .processingCode(1100)\n114\t                    .attributeFingerprint(\"fp-\" + i)\n115\t                    .lastReqVersion(\"1\")\n116\t                    .createdAt(t)\n117\t                    .updatedAt(t)\n118\t                    .build();\n119\t\n120\t            batch.add(e);\n121\t        }\n122\t        entityService.saveBatch(batch);\n123\t\n124\t\n125\t        Instant t2 = Instant.now().minus(2, ChronoUnit.DAYS);\n126\t        Instant t1 = Instant.now().minus(1, ChronoUnit.DAYS);\n127\t\n128\t        Entity e2 = Entity.builder()\n129\t                .type(EntityType.USER_HOST_BINDING)\n130\t                .source(\"PORTAL\")\n131\t                .userId(\"2\")\n132\t                .hostId(\"2\")\n133\t                .adapterId(\"2\")\n134\t                .userIdentity(\"2\")\n135\t                .hostIdentity(\"2_2\")\n136\t                .processingStage(\"ENFORCED\")\n137\t                .processingCode(4101)\n138\t                .attributeFingerprint(\"fp-2\")\n139\t                .lastReqVersion(\"1\")\n140\t                .createdAt(t2)\n141\t                .updatedAt(t2)\n142\t                .build();\n143\t\n144\t        Entity e1 = Entity.builder()\n145\t                .type(EntityType.USER_HOST_BINDING)\n146\t                .source(\"PORTAL\")\n147\t                .userId(\"1\")\n148\t                .hostId(\"1\")\n149\t                .adapterId(\"1\")\n150\t                .userIdentity(\"1\")\n151\t                .hostIdentity(\"1_1\")\n152\t                .processingStage(\"ENFORCED\")\n153\t                .processingCode(4100)\n154\t                .attributeFingerprint(\"fp-1\")\n155\t                .lastReqVersion(\"1\")\n156\t                .createdAt(t1)\n157\t                .updatedAt(t1)\n158\t                .build();\n159\t\n160\t        entityService.save(e2);\n161\t        entityService.save(e1);\n162\t\n163\t        EntityQueryDTO query = new EntityQueryDTO();\n164\t        query.setPageNum(1);\n165\t        query.setPageSize(10);\n166\t        query.setSortKey(\"processingStage\");\n167\t        query.setSortOrder(\"asc\");\n168\t\n169\t        int expectedMinTotal = batch.size() + 2;\n170\t\n171\t        webClient.post()\n172\t                .uri(\"http://localhost:\" + port + \"/api/v1/entities/query\")\n173\t                .contentType(MediaType.APPLICATION_JSON)\n174\t                .bodyValue(query)\n175\t                .exchange()\n176\t                .expectStatus().isOk()\n177\t                .expectBody()\n178\t                .consumeWith(r -> System.out.println(\"RESP JSON=\" + new String(r.getResponseBody())))\n179\t                // total count\n180\t                .jsonPath(\"$.data.totalRecords\").value(v ->\n181\t                        Assertions.assertTrue(((Number) v).intValue() >= expectedMinTotal)\n182\t                )\n183\t                // list items count at leat is pageSize\n184\t                .jsonPath(\"$.data.list.length()\").value(v ->\n185\t                        Assertions.assertTrue(((Number) v).intValue() >= 10)\n186\t                )\n187\t                // first item must be e2\n188\t                .jsonPath(\"$.data.list[0].hostIdentity\").isEqualTo(\"2_2\")\n189\t                .jsonPath(\