       case EVALUATED:\n89\t                        success = handleEvaluated(entityDTO);\n90\t                        break;\n91\t                    case ENFORCED:\n92\t                        // completed\n93\t                        return StatusOr.ok(entityDTOConverter.toEntity(entityDTO));\n94\t                    default:\n95\t                        resultTag = \"fail\";\n96\t                        return StatusOr.error(Constants.BusinesCode.STATE_MACHINE_INVALID_ENTITY_STAGE,\n97\t                                \"Invalid stage: \" + stage);\n98\t                }\n99\t\n100\t                if (!success) {"}]},"parent_tool_use_id":"toolu_01YYYKrvBpaorwFWK2cTBtHz","session_id":"f740dd01-4690-4d22-a717-b6b57116b679","uuid":"aa5ebc92-ad5b-4ea3-a2cc-aeedf821a4e2","timestamp":"2026-04-20T08:25:57.869Z"}
