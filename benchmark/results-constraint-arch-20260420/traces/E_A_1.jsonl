amework.boot</groupId>\n91\t            <artifactId>spring-boot-devtools</artifactId>\n92\t            <!-- runtime: Not needed during compile time, but used during runtime, and not packaged in the production JAR -->\n93\t            <!-- Compile time: Your source code does not directly import classes from devtools, so it's not needed during compilation. -->\n94\t            <!-- Runtime: Spring Boot automatically detects and loads hot reload features from devtools during startup. -->\n95\t            <!-- runtime tells Maven:\n96\t                 \"I don’t need to include its classes at compile time,\n97\t                  but I want it on the classpath at runtime.\" -->\n98\t            <scope>runtime</scope>\n99\t            <!-- optional: true means that if module A depends on current module, A won't inherit devtools; A must declare it explicitly to use. -->\n100\t            <optional>true</optional>\n101\t        </dependency>\n102\t\n103\t        <dependency>\n104\t            <groupId>org.projectlombok</groupId>\n105\t            <artifactId>lombok</artifactId>\n106\t            <optional>true</optional>\n107\t        </dependency>\n108\t\n109\t        <dependency>\n110\t            <groupId>org.springframework.boot</groupId>\n111\t            <artifactId>spring-boot-starter-test</artifactId>\n112\t            <!-- scope: test means it's only effective during testing (e.g., mvn test).\n113\t                 It will not be included in the final packaged JAR. -->\n114\t            <scope>test</scope>\n115\t        </dependency>\n116\t\n117\t        <dependency>\n118\t            <groupId>org.springframework.boot</groupId>\n119\t            <artifactId>spring-boot-starter-webflux</artifactId>\n120\t        </dependency>\n121\t\n122\t        <dependency>\n123\t            <groupId>commons-codec</groupId>\n124\t            <artifactId>commons-codec</artifactId>\n125\t        </dependency>\n126\t\n127\t    </dependencies>\n128\t\n129\t    <build>\n130\t        <f