{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DrugjunEE38bMZwDQuPPjB","type":"tool_result","content":"1\tpackage com.fortinet.nac.ingestion.repository;\n2\t\n3\timport com.fortinet.nac.ingestion.entity.Entity;\n4\timport com.fortinet.nac.common.enums.EntityType;\n5\timport com.fortinet.nac.common.enums.ReprocessState;\n6\timport com.fortinet.nac.ingestion.repository.projection.EntityProcessLockInfo;\n7\timport org.springframework.data.domain.Page;\n8\timport org.springframework.data.domain.Pageable;\n9\timport org.springframework.data.jpa.repository.*;\n10\timport org.springframework.data.repository.query.Param;\n11\t\n12\timport java.time.Instant;\n13\timport java.util.List;\n14\timport java.util.Optional;\n15\t\n16\tpublic interface EntityRepository extends JpaRepository<Entity, Long>, JpaSpecificationExecutor<Entity> {\n17\t\n18\t    Optional<Entity> findFirstByTypeAndHostIdentity(EntityType type, String hostIdentity);\n19\t\n20\t    Optional<Entity> findFirstByTypeAndHostIdentityAndUserIdentity(EntityType type, String hostIdentity, String userIdentity);\n21\t\n22\t    @Modifying(clearAutomatically = true, flushAutomatically = true)\n23\t    @Query(\"update Entity e set e.interrupted = :interrupted, e.updatedAt = :updatedAt where e.id = :id\")\n24\t    int updateInterrupted(@Param(\"id\") Long id,\n25\t                          @Param(\"interrupted\") boolean interrupted,\n26\t                          @Param(\"updatedAt\") Instant updatedAt);\n27\t\n28\t    @Modifying(clearAutomatically = true, flushAutomatically = true)\n29\t    @Query(\n30\t            \"update Entity e \" +\n31\t                    \"set e.interrupted = :interrupted, \" +\n32\t                    \"    e.attributeFingerprint = :fp, \" +\n33\t                    \"    e.processingStage = :stage, \" +\n34\t                    \"    e.processingCode = :code, \" +\n35\t                    \"    e.lastReqVersion = :version, \" +\n36\t                    \"    e.processingResult = :processingResult, \" +\n37\t                    \"    e.updatedAt = :updatedAt \" +\n38\t                    \"where e.id = :id\"\n39\t    )\n40\t    int updateProcessingState(\n41\t            @Param(\"id\") Long id,\n42\t            @Param(\"interrupted\") boolean interrupted,\n43\t            @Param(\"fp\") String fp,\n44\t            @Param(\"stage\") String stage,\n45\t            @Param(\"code\") Integer code,\n46\t            @Param(\"version\") String version,\n47\t            @Param(\"processingResult\") String processingResult,\n48\t            @Param(\"updatedAt\") Instant updatedAt\n49\t    );\n50\t\n51\t    /**\n52\t     * Query entities that are \"suspected to be stuck\":\n53\t     *  - Not yet ENFORCED\n54\t     *  - No failure code (processingCode = 0 or null)\n55\t     *  - updatedAt is too long ago\n56\t     *  Includes interrupted entities, because they may need recovery\n57\t     */\n58\t    @Query(\n59\t            \"select e from Entity e \" +\n60\t                    \"where e.processingStage <> 'ENFORCED' \" +\n61\t                    \"  and (e.processingCode = 0 or e.processingCode is null) \" +\n62\t                    \"  and e.updatedAt < :before \" +\n63\t                    \"order by e.updatedAt asc\"\n64\t    )\n65\t    Page<Entity> findStuckEntities(@Param(\"before\") Instant before, Pageable pageable);\n66\t\n67\t    // only return id, to reduce resource usage.\n68\t    @Query(\n69\t            \"SELECT e.id FROM Entity e \" +\n70\t                    \"WHERE e.id > :lastId \" +\n71\t                    \"  AND (e.reprocessState <> :targetState OR e.reprocessState IS NULL) \" +\n72\t                    \"ORDER BY e.id\"\n73\t    )\n74\t    List<Long> findTopNIdsNeedMarkForReprocess(@Param(\"lastId\") Long lastId,\n75\t                                               @Param(\"targetState\") ReprocessState targetState,\n76\t                                               Pageable pageable);\n77\t\n78\t    @Modifying\n79\t    @Query(\n80\t            \"UPDATE Entity e \" +\n81\t                    \"SET e.reprocessState = :targetState, e.updatedAt = CURRENT_TIMESTAMP \" +\n82\t                    \"WHERE e.id IN :ids AND (e.reprocessState <> :targetState OR e.reprocessState IS NULL)\"\n83\t    )\n84\t    int markBatchForReprocess(@Param(\"ids\") List<Long> ids,\n85\t                              @Param(\"targetState\") ReprocessState targetState);\n86\t\n87\t    @Query(\"SELECT e.id FROM Entity e WHERE e.reprocessState = :state ORDER BY e.id\")\n88\t    List<Long> findTopNIdsByReprocessState(@Param(\"state\") ReprocessState state, Pageable pageable);\n89\t\n90\t    /**\n91\t     * Lightweight projection for lock-key + state check in reprocess job.\n92\t     */\n93\t    @Query(\n94\t            \"SELECT e.id AS id, \" +\n95\t                    \"e.type AS type, \" +\n96\t                    \"e.hostId AS hostId, \" +\n97\t                    \"e.adapterId AS adapterId, \" +\n98\t                    \"e.userId AS userId, \" +\n99\t                    \"e.reprocessState AS reprocessState \" +\n100\t                    \"FROM Entity e WHERE e.id = :id\"\n101\t    )\n102\t    Optional<EntityProcessLockInfo> findProcessLockInfoById(@Param(\"id\") Long id);\n103\t\n104\t    /**\n105\t     * Atomic claim: only one worker can move an INIT entity to RUNNING.\n106\t     */\n107\t    @Modifying(clearAutomatically = true, flushAutomatically = true)\n108\t    @Query(\n109\t            \"UPDATE Entity e \" +\n110\t                    \"SET e.reprocessState = 'RUNNING', e.updatedAt = :updatedAt \" +\n111\t                    \"WHERE e.id = :id AND e.reprocessState = 'INIT'\"\n112\t    )\n113\t    int claimInitEntityForReprocess(@Param(\"id\") Long id, @Param(\"updatedAt\") Instant updatedAt);\n114\t\n115\t    @Modifying(clearAutomatically = true, flushAutomatically = true)\n116\t    @Query(\n117\t            \"UPDATE Entity e \" +\n118\t                    \"SET e.reprocessState = :state, e.updatedAt