{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016a1fUCJF4MXpJBFBJi4Eat","type":"tool_result","content":"1\tpackage com.fortinet.nac.ingestion.job;\n2\t\n3\timport com.fortinet.nac.common.Constants;\n4\timport com.fortinet.nac.common.enums.EntityStage;\n5\timport com.fortinet.nac.common.enums.ReprocessState;\n6\timport com.fortinet.nac.common.redis.DistributedLock;\n7\timport com.fortinet.nac.common.util.StatusOr;\n8\timport com.fortinet.nac.ingestion.consumer.statemachine.EntityStateMachine;\n9\timport com.fortinet.nac.ingestion.entity.Entity;\n10\timport com.fortinet.nac.ingestion.job.event.PolicyReprocessRequestedEvent;\n11\timport com.fortinet.nac.ingestion.repository.projection.EntityProcessLockInfo;\n12\timport com.fortinet.nac.ingestion.service.EntityService;\n13\timport com.fortinet.nac.ingestion.util.RedisUtil;\n14\timport io.micrometer.core.instrument.Counter;\n15\timport io.micrometer.core.instrument.MeterRegistry;\n16\timport io.micrometer.core.instrument.Timer;\n17\timport lombok.RequiredArgsConstructor;\n18\timport lombok.extern.slf4j.Slf4j;\n19\timport org.springframework.beans.factory.annotation.Value;\n20\timport org.springframework.context.event.EventListener;\n21\timport org.springframework.scheduling.annotation.Async;\n22\timport org.springframework.scheduling.annotation.Scheduled;\n23\timport org.springframework.stereotype.Component;\n24\t\n25\timport javax.annotation.PostConstruct;\n26\timport javax.annotation.Resource;\n27\timport java.util.ArrayList;\n28\timport java.util.List;\n29\timport java.util.UUID;\n30\timport java.util.concurrent.CompletableFuture;\n31\timport java.util.concurrent.Executor;\n32\timport java.util.concurrent.TimeUnit;\n33\timport java.util.concurrent.atomic.AtomicInteger;\n34\t\n35\t@Component\n36\t@RequiredArgsConstructor\n37\t@Slf4j\n38\tpublic class PolicyReprocessJob {\n39\t\n40\t    private final EntityService entityService;\n41\t    private final DistributedLock distributedLock;\n42\t    private final EntityStateMachine stateMachine;\n43\t    private final MeterRegistry meterRegistry;\n44\t    private final AtomicInteger scanLockConsecutiveFailures = new AtomicInteger(0);\n45\t    @Resource(name = \"policyReprocessJobExecutor\")\n46\t    private Executor policyReprocessJobExecutor;\n47\t\n48\t    @Value(\"${policy.reprocess.scan-batch-size:${policy.reprocess.batch-size:100}}\")\n49\t    private int scanBatchSize;\n50\t\n51\t    @Value(\"${policy.reprocess.max-candidates-per-scan:${policy.reprocess.max-entities-per-scan:1000}}\")\n52\t    private int maxCandidatesPerScan;\n53\t\n54\t    @Value(\"${policy.reprocess.rate-limit-per-second:100}\")\n55\t    private int rateLimitPerSecond;\n56\t\n57\t    @Value(\"${policy.reprocess.scan-lock-ttl-seconds:900}\")\n58\t    private int scanLockTtlSeconds;\n59\t\n60\t    @PostConstruct\n61\t    public void initMetrics() {\n62\t        // Gauge for starvation visibility: how many scan-lock failures occurred continuously.\n63\t        meterRegistry.gauge(\"policy_reprocess_scan_lock_consecutive_failures\", scanLockConsecutiveFailures);\n64\t    }\n65\t\n66\t    @Scheduled(fixedDelayString = \"${policy.reprocess.scan-interval-ms:30000}\")\n67\t    public void scanAndReprocessInitEntities() {\n68\t        triggerScan(\"scheduled\");\n69\t    }\n70\t\n71\t    @Async(\"policyReprocessListenerExecutor\")\n72\t    @EventListener\n73\t    public void onPolicyReprocessRequested(PolicyReprocessRequestedEvent event) {\n74\t        log.info(\"PolicyReprocessJob: receive reprocess trigger from {}, markedCount={}\",\n75\t                event.getTriggerSource(), event.getMarkedCount());\n76\t        triggerScan(\"event\");\n77\t    }\n78\t\n79\t    private void triggerScan(String triggerSource) {\n80\t        // PolicyReprocessJob currently runs on a single node, so distributed contention is limited.\n81\t        // Keep the distributed scan lock for future cluster deployments to prevent concurrent full scans.\n82\t        // Global scan lock uses fixed TTL to avoid indefinite lock extension when scan thread is stuck.\n83\t        boolean acquired = distributedLock.tryLock(\n84\t                Constants.RedisKeys.POLICY_REPROCESS_SCAN_LOCK_KEY,\n85\t                Math.max(1, scanLockTtlSeconds));\n86\t        recordLockAcquire(\"scan\", acquired);\n87\t        if (!acquired) {\n88\t            scanLockConsecutiveFailures.incrementAndGet();\n89\t            log.warn(\"PolicyReprocessJob: skip {} trigger because global scan lock is held\", triggerSource);\n90\t            return;\n91\t        }\n92\t        scanLockConsecutiveFailures.set(0);\n93\t\n94\t        Timer.Sample lockHoldSample = Timer.start(meterRegistry);\n95\t\n96\t        try {\n97\t            drainInitEntities();\n98\t        } finally {\n99\t            distributedLock.unLock(Constants.RedisKeys.POLICY_REPROCESS_SCAN_LOCK_KEY);\n100\t            lockHoldSample.stop(lockHoldTimer(\"scan\"));\n101\t        }\n102\t    }\n103\t\n104\t    private void drainInitEntities() {\n105\t        int effectiveBatchSize = Math.max(1, scanBatchSize);\n106\t        int effectiveMaxCandidatesPerScan = Math.max(1, maxCandidatesPerScan);\n107\t\n108\t        ReprocessRateLimiter rateLimiter = new ReprocessRateLimiter(rateLimitPerSecond, meterRegistry);\n109\t\n110\t        int totalScannedCandidates = 0;\n111\t        while (totalScannedCandidates < effectiveMaxCandidatesPerScan) {\n112\t\n113\t            // Respect scan-level protection limit to avoid too much one-shot pressure.\n114\t            int queryLimit = Math.min(effectiveBatchSize, effectiveMaxCandidatesPerScan - totalScannedCandidates);\n115\t\n116\t            // Query only ids first to avoid fetching large columns such as processingResult.\n117\t            List<Long> batchIds = entityService.findTopNIdsByReprocessState(\n118\t                    ReprocessState.INIT, queryLimit);\n119\t            if (batchIds.isEmpty()) {\n120\t                break;\n121\t            }\n122\t            totalScannedCandidates += batchIds.size();\n123\t\n124\t            processBatchConcurrently(batchIds, rateLimiter);\n125\t            log.info(\"PolicyReprocessJob: batch processed, size={}\", batchIds.size());\n126\t\n127\t            // If we got fewer than one full batch, queue is likely drained for this run.\n128\t            if (batchIds.size() < queryLimit) {\n129\t                break;\n130\t            }\n131\t        }\n132\t    }\n133\t\n134\t    private void processBatchConcurrently(List<Long> batchIds, ReprocessRateLimiter rateLimiter) {\n135\t        List<CompletableFuture<Void>> futures = new ArrayList<>(batchIds.size());\n136\t        for (Long entityId : batchIds) {\n137\t            futures.add(CompletableFuture.runAsync(\n138\t                    () -> reprocessOneEntitySafely(entityId, rateLimiter),\n139\t                    policyReprocessJobExecutor\n140\t            ));\n141\t        }\n142\t\n143\t        CompletableFuture.allOf(futures.toArray(new CompletableFuture[0])).join();\n144\t    }\n145\t\n146\t    private void reprocessOneEntitySafely(Long entityId, ReprocessRateLimiter rateLimiter) {\n147\t        try {\n148\t            reprocessOneEntity(entityId, rateLimiter);\n149\t        } catch (Exception ex) {\n150\t            log.error(\"PolicyReprocessJob: reprocess entity {} failed, err={}\",\n151\t                    entityId, ex.toString(), ex);\n152\t        }\n153\t    }\n154\t\n155\t    private void reprocessOneEntity(Long entityId, ReprocessRateLimiter rateLimiter) {\n156\t        // First read only lock-related fields to avoid loading large columns too early.\n157\t        EntityProcessLockInfo lockInfo = entityService.findProcessLockInfoById(entityId);\n158\t        if (lockInfo == null) {\n159\t            log.warn(\"PolicyReprocessJob: entity {} not found\", entityId);\n160\t            return;\n161\t        }\n162\t\n163\t        if (lockInfo.getReprocessState() != ReprocessState.INIT) {\n164\t            // State already changed by another flow, skip.\n165\t            return;\n166\t        }\n167\t\n168\t        // 1) Acquire processLock first to avoid conflict with normal ingestion flow.\n169\t        String processLockKey = RedisUtil.getEntityProcessLockKey(\n170\t                lockInfo.getType(), lockInfo.getHostId(), lockInfo.getAdapterId(), lockInfo.getUserId());\n171\t        boolean locked = distributedLock.tryLock(\n172\t                processLockKey, Constants.RedisKeys.ENTITY_PROCESS_LOCK_TTL);\n173\t        recordLockAcquire(\"entity\", locked);\n174\t\n175\t        if (!locked) {\n176\t            // The entity is being handled by other flow; retry next round.\n177\t            log.info(\"PolicyReprocessJob: skip entity {} because processLock is held\", entityId);\n178\t            return;\n179\t        }\n180\t\n181\t        Timer.Sample lockHoldSample = Timer.start(meterRegistry);\n182\t        try {\n183\t            // Atomic claim in DB: only one worker can move INIT -> RUNNING.\n184\t            // claimInitEntityForReprocess is essentially a claim operation for processing ownership:\n185\t            //   it turns \"check INIT then set RUNNING\" into one atomic step to remove race windows.\n186\t            boolean claimed = entityService.claimInitEntityForReprocess(entityId);\n187\t            if (!claimed) {\n188\t                return;\n189\t            }\n190\t\n191\t            // Load full entity only after claim succeeds.\n192\t            Entity fresh = entityService.getEntity(entityId);\n193\t            if (fresh == null) {\n194\t                log.warn(\"PolicyReprocessJob: entity {} missing after claim\", entityId);\n195\t                return;\n196\t            }\n197\t\n198\t            // 2) Reset business processing state so state machine can replay.\n199\t            resetEntityProcessingState(fresh);\n200\t            boolean ok = entityService.updateProcessingState(fresh);\n201\t            if (!ok) {\n202\t                log.error(\"PolicyReprocessJob: failed to reset processing state, entityId={}\", entityId);\n203\t                boolean updated = entityService.updateReprocessStateById(entityId, ReprocessState.FAILED);\n204\t                if (!updated) {\n205\t                    log.warn(\"PolicyReprocessJob: failed to update FAILED reprocess state, entityId={}\", entityId);\n206\t                }\n207\t                recordReprocessCompletion(\"failed\");\n208\t                return;\n209\t            }\n210\t\n211\t            // 3) Run state machine with rate limiting to protect downstream.\n212\t            rateLimiter.acquire();\n213\t            String requestId = generateRequestId();\n214\t            StatusOr<Entity> result = stateMachine.start(requestId, true, fresh);\n215\t\n216\t            // 4) Update final reprocessState by state machine result.\n217\t            if (result.ok()) {\n218\t                Entity finalEntity = result.getValue();\n219\t                if (EntityStage.ENFORCED.toString().equals(finalEntity.getProcessingStage()) &&\n220\t                        finalEntity.getProcessingCode() == 0) {\n221\t                    finalEntity.setReprocessState(ReprocessState.SUCCESS);\n222\t                } else {\n223\t                    finalEntity.setReprocessState(ReprocessState.FAILED);\n224\t                }\n225\t\n226\t                // Persist the state-machine final snapshot to avoid overriding it with stale \"fresh\".\n227\t                entityService.save(finalEntity);\n228\t                if (finalEntity.getReprocessState() == ReprocessState.SUCCESS) {\n229\t                    recordReprocessCompletion(\"success\");\n230\t                } else {\n231\t                    recordReprocessCompletion(\"failed\");\n232\t                }\n233\t            } else {\n234\t                // State-machine returned error; update FAILED by id to avoid another full-row read.\n235\t                boolean updated = entityService.updateReprocessStateById(entityId, ReprocessState.FAILED);\n236\t                if (!updated) {\n237\t                    log.warn(\"PolicyReprocessJob: failed to update FAILED state after state machine error, entityId={}\", entityId);\n238\t                }\n239\t                recordReprocessCompletion(\"failed\");\n240\t            }\n241\t\n242\t        } finally {\n243\t            distributedLock.unLock(processLockKey);\n244\t            lockHoldSample.stop(lockHoldTimer(\"entity\"));\n245\t        }\n246\t    }\n247\t\n248\t    // update in memory\n249\t    private void resetEntityProcessingState(Entity e) {\n250\t        e.setInterrupted(false);\n251\t        e.setProcessingStage(EntityStage.PENDING.toString());\n252\t        e.setProcessingCode(0);\n253\t        e.setProcessingResult(\"{}\");\n254\t        e.setErrorMessage(\"\");\n255\t        // Keep lastReqVersion unchanged.\n256\t    }\n257\t\n258\t    private String generateRequestId() {\n259\t        return UUID.randomUUID().toString().replace(\"-\", \"\").substring(0, 16);\n260\t    }\n261\t\n262\t    private void recordLockAcquire(String lockName, boolean success) {\n263\t        meterRegistry.counter(\n264\t                \"policy_reproc_lock_acquire_total\",\n265\t                \"lock\", lockName,\n266\t                \"result\", success ? \"success\" : \"failed\"\n267\t        ).increment();\n268\t    }\n269\t\n270\t    private void recordReprocessCompletion(String result) {\n271\t        meterRegistry.counter(\n272\t                \"policy_reprocess_entity_completed_total\",\n273\t                \"result\", result\n274\t        ).increment();\n275\t    }\n276\t\n277\t    private Timer lockHoldTimer(String lockName) {\n278\t        return Timer.builder(\"policy_reproc_lock_hold_seconds\")\n279\t                .tag(\"lock\", lockName)\n280\t                .register(meterRegistry);\n281\t    }\n282\t\n283\t    // ReprocessRateLimiter is a per-second limiter used to protect downstream systems.\n284\t    // It prevents PolicyReprocessJob from reprocessing too many entities in a short time.\n285\t    private static final class ReprocessRateLimiter {\n286\t        private static final long ONE_SECOND_NANOS = TimeUnit.SECONDS.toNanos(1);\n287\t\n288\t        // Token bucket refill rate: number of tokens added per second.\n289\t        private final int refillTokensPerSecond;\n290\t        // Bucket capacity: allows short bursts while keeping an upper bound.\n291\t        private final double capacity;\n292\t        // Count how many acquire() calls were throttled (had to wait).\n293\t        private final Counter waitCounter;\n294\t\n295\t        private double availableTokens;\n296\t        private long lastRefillNanos = System.nanoTime();\n297\t\n298\t        private ReprocessRateLimiter(int maxPerSecond, MeterRegistry meterRegistry) {\n299\t            this.refillTokensPerSecond = Math.max(0, maxPerSecond);\n300\t            this.capacity = this.refillTokensPerSecond <= 0 ? 0.0 : this.refillTokensPerSecond;\n301\t            this.availableTokens = this.capacity;\n302\t            this.waitCounter = meterRegistry.counter(\"policy_reprocess_rate_limiter_wait_total\");\n303\t        }\n304\t\n305\t        // Call acquire() before each processing attempt, right before stateMachine.start(...).\n306\t        private synchronized void acquire() {\n307\t            if (refillTokensPerSecond <= 0) {\n308\t                return;\n309\t            }\n310\t\n311\t            refillTokens();\n312\t\n313\t            if (availableTokens < 1.0) {\n314\t                long waitNanos = nanosUntilNextToken();\n315\t                if (waitNanos > 0) {\n316\t                    waitCounter.increment();\n317\t                    try {\n318\t                        TimeUnit.NANOSECONDS.sleep(waitNanos);\n319\t                    } catch (InterruptedException ex) {\n320\t                        Thread.currentThread().interrupt();\n321\t                        return;\n322\t                    }\n323\t                }\n324\t                refillTokens();\n325\t            }\n326\t\n327\t            // If availableTokens >= 1, consume one token and proceed immediately.\n328\t            if (availableTokens >= 1.0) {\n329\t                availableTokens -= 1.0;\n330\t            } else {\n331\t                // Floating-point safety fallback.\n332\t                availableTokens = 0.0;\n333\t            }\n334\t        }\n335\t\n336\t        // Refill tokens based on elapsed time.\n337\t        private void refillTokens() {\n338\t            long now = System.nanoTime();\n339\t            long elapsedNanos = now - lastRefillNanos;\n340\t            if (elapsedNanos <= 0) {\n341\t                return;\n342\t            }\n343\t\n344\t            // Cap refill amount so available tokens never exceed capacity.\n345\t            double tokensToAdd = (elapsedNanos / (double) ONE_SECOND_NANOS) * refillTokensPerSecond;\n346\t            if (tokensToAdd <= 0.0) {\n347\t                return;\n348\t            }\n349\t\n350\t            availableTokens = Math.min(capacity, availableTokens + tokensToAdd);\n351\t            lastRefillNanos = now;\n352\t        }\n353\t\n354\t        // Sleep until at least one token is available.\n355\t        private long nanosUntilNextToken() {\n356\t            double missingTokens = 1.0 - availableTokens;\n357\t            if (missingTokens <= 0.0 || refillTokensPerSecond <= 0) {\n358\t                return 0L;\n359\t            }\n360\t\n361\t            return (long) Math.ceil((missingTokens / refillTokensPerSecond) * ONE_SECOND_NANOS);\n362\t        }\n363\t    }\n364\t}\n365\t"}]},"parent_tool_use_id":"toolu_01Azs2HBfp8zD7reSELJzXeD","session_id":"96ee62c5-d876-46ad-aa4f-f8b05d56b121","uuid":"c5cd742d-bd69-4ad0-a125-83653d9ad07f","timestamp":"2026-04-20T08:31:58.759Z"}
