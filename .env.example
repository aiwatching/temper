# TEMPER environment template.
#
# How to use:
#   cp .env.example .env        # local dev OR docker compose
#   vi .env                     # fill in the required values below
#
# install.sh does this copy + appends SECRET_KEY / dev admin creds
# automatically. For docker prod (no install.sh), copy by hand.
#
# Sections marked [REQUIRED] must be set. [OPTIONAL] has a default
# but you usually want to override. [DOCKER] only applies when
# running `docker compose up`. [NATIVE] only applies when running
# uvicorn directly (./start.sh / scripts/dev.sh).


# ====================================================================
# [REQUIRED]  Service identity
# ====================================================================

# `openssl rand -base64 48` — anything strong + random.
# install.sh generates one automatically on `cp`. NEVER commit a real one.
SECRET_KEY=change-me-to-a-long-random-string

# `development` for laptops; `production` for any deploy. Affects log
# format defaults, error verbosity, and a couple of safety toggles.
APP_ENV=development

LOG_LEVEL=INFO
# `text` is human-readable for local; `json` is line-delimited for ELK / loki / datadog.
LOG_FORMAT=text


# ====================================================================
# [REQUIRED]  Database
# ====================================================================
# Pick ONE of the two paths below. They can't both be live, but they
# MUST match (the app sees one DATABASE_URL no matter which path you
# used to set it).

# ---- [DOCKER] path ----
# docker-compose.yml reads these three to initialize the postgres
# container AND to build DATABASE_URL for the memory-service container
# via the compose `environment:` block. So in docker mode you only
# fill these three; DATABASE_URL below stays as the dev fallback.
POSTGRES_USER=memory
POSTGRES_PASSWORD=memory
POSTGRES_DB=memory_service

# ---- [NATIVE] path ----
# When running uvicorn directly (./start.sh) the app reads DATABASE_URL
# from here. install.sh keeps this in sync with the postgres container
# port it picked. For prod-native, set this to your real Postgres URL
# (and ignore the POSTGRES_* triplet above — they're docker-only).
DATABASE_URL=postgresql+asyncpg://memory:memory@localhost:5432/memory_service


# ====================================================================
# [OPTIONAL]  Bundled Ollama — share with other hosts
# ====================================================================
# Port the bundled ollama is bound on the host. Other machines (Forge
# KB, etc.) can use this GPU-backed ollama by setting their embedding
# base URL to http://<this-host>:<OLLAMA_PORT>/v1. Ollama has NO auth;
# only expose on trusted networks. Set to "127.0.0.1:11434" in
# docker-compose.yml (edit by hand) to restrict to localhost.
OLLAMA_PORT=11434


# ====================================================================
# [REQUIRED]  FalkorDB (graphiti backend)
# ====================================================================
# Where the graph database lives. In docker mode the compose override
# binds it on the host port — see HOST_FALKORDB_PORT in
# docker-compose.dev.yml. In native mode point at wherever you installed
# FalkorDB (defaults assume the dev convention: docker on host port 6380).
FALKORDB_HOST=localhost
FALKORDB_PORT=6380
FALKORDB_PASSWORD=
# Browser UI port. 0 disables. Local-only by default.
FALKORDB_BROWSER_PORT=3000


# ====================================================================
# [REQUIRED]  LLM provider (entity + relation extraction via Graphiti)
# ====================================================================
# One of: openai | deepseek | anthropic | ollama
# Per-provider hints (leave LLM_BASE_URL / LLM_MODEL empty to use defaults):
#   openai     base=https://api.openai.com/v1        model=gpt-4o-mini
#   deepseek   base=https://api.deepseek.com/v1      model=deepseek-chat
#   anthropic  base=https://api.anthropic.com        model=claude-3-5-haiku-latest
#   ollama     base=http://localhost:11434/v1        model=qwen2.5:14b-instruct
# Anthropic needs the extra: pip install "graphiti-core[anthropic]"
# Ollama doesn't need LLM_API_KEY (any string works).
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_TEMPERATURE=0.0


# ====================================================================
# [REQUIRED]  Embedding provider (vectorizes facts/entities)
# ====================================================================
# One of: openai | ollama
# Independent from LLM_PROVIDER — common combo is deepseek + openai
# because DeepSeek has no embeddings API.
#   openai  base=https://api.openai.com/v1        model=text-embedding-3-small  dim=1536
#   ollama  base=http://localhost:11434/v1        model=nomic-embed-text        dim=768
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=


# ====================================================================
# [OPTIONAL]  Search
# ====================================================================
# Default reranking strategy for /v1/search. Per-request override via
# ?reranker=... on the API or --reranker on memctl.
#   rrf            (default) Reciprocal Rank Fusion. Free, fast.
#   mmr            Maximal Marginal Relevance. Diversifies results.
#   cross_encoder  LLM-rescored. Slower + token cost per query, but
#                  best relevance ordering. Needs an OpenAI-compatible
#                  LLM endpoint to be configured.
SEARCH_RERANKER=rrf


# ====================================================================
# [OPTIONAL]  Onboarding + auth
# ====================================================================

# Self-registration policy. `true` for solo-dev / sandbox. `false` is
# the production answer — users come in only via admin-issued invites
# (POST /v1/users) or BOOTSTRAP_SUPER_ADMIN_EMAIL below.
ALLOW_SELF_REGISTRATION=true

# First-boot bootstrap: if the users table is empty, seed a default
# super_admin so you can log in immediately. install.sh sets these.
# For prod, prefer BOOTSTRAP_SUPER_ADMIN_EMAIL below — disable this
# once you have real users.
CREATE_DEFAULT_ADMIN=true
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin

# First user with this email is auto-promoted to super_admin on
# register. Drop this after the first deployment if you don't want it
# re-promoting anyone — existing super_admins keep their flag.
BOOTSTRAP_SUPER_ADMIN_EMAIL=


# ====================================================================
# [OPTIONAL]  HTTP surface
# ====================================================================

# Where the service binds. 127.0.0.1 = "only reachable from this host"
# — put nginx in front. 0.0.0.0 = "anyone who can reach this host's IP"
# — only do that if you trust the network (private VPC, internal-only,
# behind a firewall).
MS_BIND=127.0.0.1
MS_PORT=18088

# CORS — comma-separated allowlist of origins your frontends serve from.
# Empty disables CORS entirely (browser blocks any cross-origin call).
# "*" only for dev sandboxes.
CORS_ALLOW_ORIGINS=


# ====================================================================
# [OPTIONAL]  Per-user memory snapshots
# ====================================================================
# Built-in scheduler that backs up each user's memory (blocks +
# documents) on a schedule, so users can self-restore to an earlier
# day via /v1/me/snapshots. Stored in Postgres → covered by
# `./deploy.sh backup` automatically.
SNAPSHOT_ENABLED=true
# Hours between a user's auto snapshots.
SNAPSHOT_INTERVAL_HOURS=24
# How many auto snapshots to keep per user (older pruned). 30 ≈ a
# month of daily history. Manual snapshots are never auto-pruned.
SNAPSHOT_RETENTION=30


# ====================================================================
# [OPTIONAL]  Telemetry / privacy
# ====================================================================

# Graphiti's anonymous PostHog telemetry. Keep off behind any
# TLS-inspecting proxy or air-gapped network.
GRAPHITI_TELEMETRY_ENABLED=false


# ====================================================================
# [DOCKER]  Build-time only
# ====================================================================

# Set to "1" only when building from inside a TLS-inspecting corporate
# network (self-signed CA in the chain) that breaks pypi cert
# verification. Tells the Dockerfile to pass --trusted-host on pip
# install. Builds on regular internet should leave this empty.
PIP_TRUSTED_HOSTS=
