# Smith — personal company-level agent (TypeScript / pi-coding-agent)

# --- TEMPER (memory service) ---
TEMPER_BASE_URL=http://127.0.0.1:18088
# Smith authenticates as a real TEMPER user via API key. Create one on
# /admin/integrate — pick a slug like "smith" so memory is scoped under
# agent:<your-user-id>/smith.
TEMPER_API_KEY=mk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- LLM ---
# Smith uses pi-ai's multi-provider client under the hood. We keep
# provider-agnostic env var names here; config.ts maps them to the
# names pi-ai actually reads (ANTHROPIC_API_KEY / ANTHROPIC_OAUTH_TOKEN /
# OPENAI_API_KEY / DEEPSEEK_API_KEY / GEMINI_API_KEY).
#
# Production should point at your company's internal LLM gateway, not
# at a public cloud provider. Fill in whatever's appropriate.
# Model ID must exist in pi-ai's catalog (see
# node_modules/@earendil-works/pi-ai/dist/models.generated.d.ts) or be
# registered via pi's auth config — out of scope for the MVP scaffold.
LLM_PROVIDER=<your-provider>
LLM_API_KEY=<your-llm-api-key>
LLM_MODEL=<your-model-id>

# --- MCP servers Smith should connect to ---
# Comma-separated `name=URL` pairs. URL schemes:
#   stdio:///absolute/path/to/binary   spawn binary, no args (wrap in shell for args)
#   http(s)://host/mcp                 HTTP-streamable MCP server
# Example:
#   MCP_SERVERS=files=stdio:///usr/local/bin/mcp-filesystem,jira=https://jira-mcp.acme.internal/mcp
MCP_SERVERS=

# --- Smith control plane ---
# Smith's own HTTP. Default 18099 sits next to TEMPER (18088).
SMITH_HOST=127.0.0.1
SMITH_PORT=18099

# Bearer secret for /chat, /approve, /deny, /pending. Empty = no auth
# (dev only — pair with SMITH_HOST=127.0.0.1). Any non-loopback bind
# MUST set this. Open the UI as http://<host>:<port>/#secret=<value> —
# the page reads the hash, persists to sessionStorage, scrubs the URL.
SMITH_SECRET=

# --- Periodic consolidate ---
# 0 / unset = disabled. When >0, Smith runs `consolidate plan` every
# N hours against its own scope. Logs to .data/audit.log.
CONSOLIDATE_SCHEDULE_HOURS=0
# When true AND a scheduled plan has actions, auto-apply it without
# UI confirmation. When false, log the plan and stop — you click
# Apply in /admin/consolidate manually.
CONSOLIDATE_AUTO_APPLY=false
