# Smith — personal company-level agent

# Where Temper is reachable. Smith is a Temper client.
TEMPER_BASE_URL=http://127.0.0.1:18088
# Smith authenticates as a real Temper user via API key. Create one on
# /admin/integrate — pick a slug like "smith" so memory is scoped.
TEMPER_API_KEY=mk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM. Provider/model is chosen per the framework decision (TBD —
# see docs/framework-comparison.md). For now this is the variable
# the placeholder loop reads.
LLM_PROVIDER=anthropic         # anthropic | openai | deepseek | ollama
LLM_API_KEY=sk-...
LLM_MODEL=claude-sonnet-4-6

# MCP servers Smith should connect to. Comma-separated list of
# `name=URL` pairs. The URL can be:
#   - http(s)://host:port/mcp     for an HTTP-streamable MCP server
#   - stdio:///path/to/binary     to launch a local stdio MCP server
# Example:
#   MCP_SERVERS=files=stdio:///usr/local/bin/mcp-filesystem,jira=https://jira-mcp.acme.internal/mcp
MCP_SERVERS=

# Where Smith's own HTTP control plane listens. Default port 18099 sits
# next to Temper (18088) so two-finger restart-everything stays simple.
SMITH_HOST=127.0.0.1
SMITH_PORT=18099
