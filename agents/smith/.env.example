# Smith — personal company-level agent (TypeScript / pi-coding-agent)

# --- TEMPER (memory service) ---
TEMPER_BASE_URL=http://127.0.0.1:18088
# Smith authenticates as a real TEMPER user via API key. Create one on
# /admin/integrate — pick a slug like "smith" so memory is scoped under
# agent:<your-user-id>/smith.
TEMPER_API_KEY=mk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- LLM ---
# Smith uses pi-ai's multi-provider client under the hood. We keep
# provider-agnostic env var names here; config.ts maps them to the
# names pi-ai actually reads (ANTHROPIC_API_KEY / ANTHROPIC_OAUTH_TOKEN /
# OPENAI_API_KEY / DEEPSEEK_API_KEY / GEMINI_API_KEY).
LLM_PROVIDER=anthropic       # anthropic | openai | deepseek | google | ollama
LLM_API_KEY=sk-...
LLM_MODEL=claude-haiku-4-5

# --- MCP servers Smith should connect to ---
# Comma-separated `name=URL` pairs. URL schemes:
#   stdio:///absolute/path/to/binary   spawn binary, no args (wrap in shell for args)
#   http(s)://host/mcp                 HTTP-streamable MCP server
# Example:
#   MCP_SERVERS=files=stdio:///usr/local/bin/mcp-filesystem,jira=https://jira-mcp.acme.internal/mcp
MCP_SERVERS=

# --- Smith control plane ---
# Smith's own HTTP. Default 18099 sits next to TEMPER (18088).
SMITH_HOST=127.0.0.1
SMITH_PORT=18099
